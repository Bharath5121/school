const mockGetMessages = jest.fn();
const mockCreateMessage = jest.fn();

jest.mock('../services/chat.repository', () => ({
  ChatRepository: jest.fn().mockImplementation(() => ({
    getMessages: mockGetMessages,
    createMessage: mockCreateMessage,
  })),
}));

jest.mock('../../config/redis', () => ({
  redis: { incr: jest.fn(), expire: jest.fn() },
}));

import { ChatService } from '../services/chat.service';
import { redis } from '../../config/redis';

const mockRedis = redis as jest.Mocked<typeof redis>;

describe('ChatService', () => {
  let service: ChatService;

  beforeEach(() => {
    jest.clearAllMocks();
    service = new ChatService();
  });

  describe('getMessages', () => {
    it('returns messages in chronological order (reversed)', async () => {
      const dbMessages = [
        { id: '3', message: 'third', createdAt: new Date('2025-01-03') },
        { id: '2', message: 'second', createdAt: new Date('2025-01-02') },
        { id: '1', message: 'first', createdAt: new Date('2025-01-01') },
      ];
      mockGetMessages.mockResolvedValue(dbMessages);

      const result = await service.getMessages('general', 20);

      expect(mockGetMessages).toHaveBeenCalledWith('general', 20, undefined);
      expect(result[0].id).toBe('1');
      expect(result[2].id).toBe('3');
    });

    it('passes the after cursor when provided', async () => {
      mockGetMessages.mockResolvedValue([]);
      const afterDate = '2025-06-01T00:00:00.000Z';

      await service.getMessages('general', 10, afterDate);

      expect(mockGetMessages).toHaveBeenCalledWith('general', 10, afterDate);
    });

    it('returns empty array when no messages exist', async () => {
      mockGetMessages.mockResolvedValue([]);

      const result = await service.getMessages('empty-channel', 50);

      expect(result).toEqual([]);
    });

    it('scopes messages to the requested channel', async () => {
      mockGetMessages.mockResolvedValue([{ id: '1', channel: 'science' }]);

      await service.getMessages('science', 10);

      expect(mockGetMessages).toHaveBeenCalledWith('science', 10, undefined);
    });
  });

  describe('sendMessage', () => {
    it('creates a message when under the rate limit', async () => {
      mockRedis.incr.mockResolvedValue(1);
      mockRedis.expire.mockResolvedValue(1 as any);
      const created = { id: 'msg-1', userId: 'u1', channel: 'general', message: 'Hello' };
      mockCreateMessage.mockResolvedValue(created);

      const result = await service.sendMessage('u1', 'general', '  Hello  ');

      expect(mockRedis.incr).toHaveBeenCalledWith('chat:rate:u1');
      expect(mockRedis.expire).toHaveBeenCalledWith('chat:rate:u1', 60);
      expect(mockCreateMessage).toHaveBeenCalledWith('u1', 'general', 'Hello');
      expect(result).toEqual(created);
    });

    it('does not set expire when rate key already exists', async () => {
      mockRedis.incr.mockResolvedValue(5);
      mockCreateMessage.mockResolvedValue({ id: 'msg-2' });

      await service.sendMessage('u1', 'general', 'Hi');

      expect(mockRedis.expire).not.toHaveBeenCalled();
    });

    it('throws 429 when rate limit is exceeded', async () => {
      mockRedis.incr.mockResolvedValue(21);

      await expect(service.sendMessage('u1', 'general', 'Spam')).rejects.toMatchObject({
        statusCode: 429,
        message: expect.stringContaining('Rate limit exceeded'),
      });
      expect(mockCreateMessage).not.toHaveBeenCalled();
    });

    it('trims whitespace from the message', async () => {
      mockRedis.incr.mockResolvedValue(1);
      mockRedis.expire.mockResolvedValue(1 as any);
      mockCreateMessage.mockResolvedValue({ id: 'msg-3' });

      await service.sendMessage('u1', 'general', '  spaced out  ');

      expect(mockCreateMessage).toHaveBeenCalledWith('u1', 'general', 'spaced out');
    });
  });
});
