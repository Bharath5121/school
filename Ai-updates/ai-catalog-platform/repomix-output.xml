<file path="backend/apps/parent/prisma/schema.prisma">
generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "users", "user_activity", "user_network"]
}

enum UserRole {
  STUDENT
  PARENT
  TEACHER
  ADMIN
  @@schema("auth")
}

model User {
  id                  String         @id @default(uuid())
  email               String         @unique
  name                String         @map("full_name")
  role                UserRole       @default(STUDENT)
  emailVerified       DateTime?      @map("email_verified_at")
  failedLoginAttempts Int            @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?      @map("locked_until")
  deletedAt           DateTime?      @map("deleted_at")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  profile       Profile?
  parentLinks   ParentChildLink[] @relation("ParentLinks")
  childLinks    ParentChildLink[] @relation("ChildLinks")
  @@map("users")
  @@schema("auth")
}

model Profile {
  userId              String    @id @map("user_id")
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarUrl           String?   @map("avatar_url")
  bio                 String?
  gradeLevel          String?   @map("grade_level")
  stream              String?
  parentEmail         String?   @map("parent_email")
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")
  learningStyle       Json?     @map("learning_style")
  preferences         Json      @default("{\"theme\": \"emerald\", \"notifications\": {\"email\": true, \"push\": false}}")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  interests Interest[]
  @@map("profiles")
  @@schema("users")
}

model Interest {
  id            BigInt   @id @default(autoincrement())
  userId        String   @map("user_id")
  fieldName     String   @map("field_name")
  interestLevel Int      @default(5) @map("interest_level")
  profile       Profile  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  createdAt     DateTime @default(now()) @map("created_at")
  @@unique([userId, fieldName])
  @@map("user_interests")
  @@schema("users")
}

enum SkillStatus {
  NOT_STARTED
  EXPLORING
  LEARNED
  @@schema("user_activity")
}

model Bookmark {
  userId     String   @map("user_id")
  feedItemId String   @map("feed_item_id")
  createdAt  DateTime @default(now()) @map("created_at")
  @@id([userId, feedItemId])
  @@index([userId])
  @@map("bookmarks")
  @@schema("user_activity")
}

model ReadingHistory {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  feedItemId       String   @map("feed_item_id")
  timeSpentSeconds Int      @default(0) @map("time_spent_seconds")
  completed        Boolean  @default(false)
  lastReadAt       DateTime @default(now()) @map("last_read_at")
  createdAt        DateTime @default(now()) @map("created_at")
  @@unique([userId, feedItemId])
  @@index([userId])
  @@index([lastReadAt])
  @@map("reading_history")
  @@schema("user_activity")
}

model UserSkillProgress {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  skillId   String      @map("skill_id")
  status    SkillStatus @default(NOT_STARTED)
  updatedAt DateTime    @updatedAt @map("updated_at")
  createdAt DateTime    @default(now()) @map("created_at")
  @@unique([userId, skillId])
  @@map("skill_progress")
  @@schema("user_activity")
}

model UserCareerExplored {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  careerJobId String   @map("career_job_id")
  exploredAt  DateTime @default(now()) @map("explored_at")
  @@unique([userId, careerJobId])
  @@map("career_explored")
  @@schema("user_activity")
}

model ContentBookmark {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  contentType String   @map("content_type")
  contentId   String   @map("content_id")
  title       String
  url         String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  @@unique([userId, contentType, contentId])
  @@index([userId])
  @@map("content_bookmarks")
  @@schema("user_activity")
}

model ParentChildLink {
  parentId  String   @map("parent_id")
  childId   String   @map("child_id")
  createdAt DateTime @default(now()) @map("created_at")
  parent User @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  child  User @relation("ChildLinks", fields: [childId], references: [id], onDelete: Cascade)
  @@id([parentId, childId])
  @@map("parent_child_links")
  @@schema("user_network")
}

model TeacherNote {
  id        String   @id @default(uuid())
  teacherId String   @map("teacher_id")
  studentId String   @map("student_id")
  parentId  String?  @map("parent_id")
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  @@index([parentId])
  @@index([studentId])
  @@map("teacher_notes")
  @@schema("user_network")
}
</file>

