}

.dark {
  --bg-base: #0B0F19;
  --bg-page: #0B0F19;
  --bg-surface: #111827;
  --bg-card: #151C2C;
  --bg-card-hover: #1A2236;
  --bg-elevated: #1E2738;
  --bg-border: rgba(148, 163, 184, 0.1);
