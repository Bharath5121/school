import { AdminService } from '../services/admin.service';

describe('AdminService', () => {
  let service: AdminService;

  beforeEach(() => {
    service = new AdminService();
    jest.clearAllMocks();
  });

  // ─── Industries ─────────────────────────────────────────────────────────────

  describe('Industries', () => {
    const industryData = { name: 'Healthcare', slug: 'healthcare', description: 'Health industry', sortOrder: 1 };
    const industry = { id: 'ind-1', ...industryData, createdAt: new Date() };

    describe('createIndustry', () => {
      it('creates and returns a new industry', async () => {
        prismaMock.industry.create.mockResolvedValue(industry);

        const result = await service.createIndustry(industryData as any);

        expect(prismaMock.industry.create).toHaveBeenCalledWith({ data: industryData });
        expect(result).toEqual(industry);
      });
    });

    describe('updateIndustry', () => {
      it('updates an existing industry', async () => {
        const updated = { ...industry, name: 'Healthcare Updated' };
        prismaMock.industry.update.mockResolvedValue(updated);

        const result = await service.updateIndustry('ind-1', { name: 'Healthcare Updated' } as any);

        expect(prismaMock.industry.update).toHaveBeenCalledWith({
          where: { id: 'ind-1' },
          data: { name: 'Healthcare Updated' },
        });
        expect(result.name).toBe('Healthcare Updated');
      });
    });

    describe('deleteIndustry', () => {
      it('deletes an industry by id', async () => {
        prismaMock.industry.delete.mockResolvedValue(industry);

        const result = await service.deleteIndustry('ind-1');

        expect(prismaMock.industry.delete).toHaveBeenCalledWith({ where: { id: 'ind-1' } });
        expect(result).toEqual(industry);
      });
    });
  });

  // ─── Models ─────────────────────────────────────────────────────────────────

  describe('Models', () => {
    const modelData = { name: 'GPT-4', slug: 'gpt-4', industrySlug: 'tech', sortOrder: 1 };
    const model = { id: 'mod-1', ...modelData, industry: { name: 'Tech', slug: 'tech' } };

    describe('createModel', () => {
      it('creates and returns a new model', async () => {
        prismaMock.aIModel.create.mockResolvedValue(model);

        const result = await service.createModel(modelData as any);

        expect(prismaMock.aIModel.create).toHaveBeenCalledWith(
          expect.objectContaining({ data: modelData }),
        );
        expect(result).toEqual(model);
      });
    });

    describe('getModelById', () => {
      it('returns model when found', async () => {
        prismaMock.aIModel.findUnique.mockResolvedValue(model);

        const result = await service.getModelById('mod-1');

        expect(prismaMock.aIModel.findUnique).toHaveBeenCalledWith(
          expect.objectContaining({ where: { id: 'mod-1' } }),
        );
        expect(result).toEqual(model);
      });

      it('throws 404 when model not found', async () => {
        prismaMock.aIModel.findUnique.mockResolvedValue(null);

        await expect(service.getModelById('missing'))
          .rejects
          .toThrow(AppError);

        await expect(service.getModelById('missing'))
          .rejects
          .toMatchObject({ statusCode: 404, message: 'Model not found' });
      });
    });

    describe('updateModel', () => {
      it('updates an existing model', async () => {
        const updated = { ...model, name: 'GPT-4o' };
        prismaMock.aIModel.findUnique.mockResolvedValue(model);
        prismaMock.aIModel.update.mockResolvedValue(updated);

        const result = await service.updateModel('mod-1', { name: 'GPT-4o' } as any);

        expect(prismaMock.aIModel.update).toHaveBeenCalledWith(
          expect.objectContaining({ where: { id: 'mod-1' }, data: { name: 'GPT-4o' } }),
        );
        expect(result.name).toBe('GPT-4o');
      });

      it('throws 404 when updating non-existent model', async () => {
        prismaMock.aIModel.findUnique.mockResolvedValue(null);

        await expect(service.updateModel('missing', { name: 'x' } as any))
          .rejects
          .toMatchObject({ statusCode: 404 });
      });
    });

    describe('deleteModel', () => {
      it('deletes an existing model', async () => {
        prismaMock.aIModel.findUnique.mockResolvedValue(model);
        prismaMock.aIModel.delete.mockResolvedValue(model);

        const result = await service.deleteModel('mod-1');

        expect(prismaMock.aIModel.delete).toHaveBeenCalledWith({ where: { id: 'mod-1' } });
        expect(result).toEqual(model);
      });

      it('throws 404 when deleting non-existent model', async () => {
        prismaMock.aIModel.findUnique.mockResolvedValue(null);

        await expect(service.deleteModel('missing'))
          .rejects
          .toMatchObject({ statusCode: 404 });
      });
    });
  });

  // ─── Agents ─────────────────────────────────────────────────────────────────

  describe('Agents', () => {
    const agentData = { name: 'Code Agent', slug: 'code-agent', industrySlug: 'tech', sortOrder: 1 };
    const agent = { id: 'agt-1', ...agentData, industry: { name: 'Tech', slug: 'tech' } };

    describe('createAgent', () => {
      it('creates and returns a new agent', async () => {
        prismaMock.aIAgent.create.mockResolvedValue(agent);

        const result = await service.createAgent(agentData as any);

        expect(prismaMock.aIAgent.create).toHaveBeenCalledWith(
          expect.objectContaining({ data: agentData }),
        );
