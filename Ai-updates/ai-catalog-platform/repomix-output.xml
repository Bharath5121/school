import { DetailService } from '../services/detail.service';
import { redis } from '../../../../config/redis';

const mockRedis = redis as jest.Mocked<typeof redis>;

describe('DetailService', () => {
  let service: DetailService;

  beforeEach(() => {
    jest.clearAllMocks();
    service = new DetailService();
  });

  describe('getIndustryDetail', () => {
    const models = [{ id: 'm1', name: 'GPT-5', industrySlug: 'healthcare' }];
    const agents = [{ id: 'a1', name: 'DiagnosticBot', industrySlug: 'healthcare' }];
    const apps = [{ id: 'app1', name: 'MedAssist', industrySlug: 'healthcare' }];

    it('returns cached result on cache hit', async () => {
      const cached = JSON.stringify({ models, agents, apps });
      mockRedis.get.mockResolvedValue(cached);

      const result = await service.getIndustryDetail('healthcare');

      expect(mockRedis.get).toHaveBeenCalledWith('industry:detail:healthcare');
      expect(result).toEqual({ models, agents, apps });
      expect(mockGetModelsByIndustry).not.toHaveBeenCalled();
    });

    it('fetches from repos and caches on cache miss', async () => {
      mockRedis.get.mockResolvedValue(null);
      mockGetModelsByIndustry.mockResolvedValue(models);
      mockGetAgentsByIndustry.mockResolvedValue(agents);
      mockGetAppsByIndustry.mockResolvedValue(apps);
      mockRedis.setex.mockResolvedValue('OK');

      const result = await service.getIndustryDetail('healthcare');

      expect(mockGetModelsByIndustry).toHaveBeenCalledWith('healthcare');
      expect(mockGetAgentsByIndustry).toHaveBeenCalledWith('healthcare');
      expect(mockGetAppsByIndustry).toHaveBeenCalledWith('healthcare');
      expect(mockRedis.setex).toHaveBeenCalledWith(
        'industry:detail:healthcare',
        1800,
        JSON.stringify({ models, agents, apps }),
      );
      expect(result).toEqual({ models, agents, apps });
    });

    it('returns empty collections when industry has no data', async () => {
      mockRedis.get.mockResolvedValue(null);
      mockGetModelsByIndustry.mockResolvedValue([]);
      mockGetAgentsByIndustry.mockResolvedValue([]);
      mockGetAppsByIndustry.mockResolvedValue([]);
      mockRedis.setex.mockResolvedValue('OK');

      const result = await service.getIndustryDetail('unknown-field');

      expect(result).toEqual({ models: [], agents: [], apps: [] });
    });

    it('fetches all three repository types in parallel', async () => {
      mockRedis.get.mockResolvedValue(null);
      mockGetModelsByIndustry.mockResolvedValue(models);
      mockGetAgentsByIndustry.mockResolvedValue(agents);
      mockGetAppsByIndustry.mockResolvedValue(apps);
      mockRedis.setex.mockResolvedValue('OK');

      await service.getIndustryDetail('healthcare');

      expect(mockGetModelsByIndustry).toHaveBeenCalledTimes(1);
      expect(mockGetAgentsByIndustry).toHaveBeenCalledTimes(1);
      expect(mockGetAppsByIndustry).toHaveBeenCalledTimes(1);
    });
  });

  describe('getModels', () => {
    it('delegates to the models repository', async () => {
      const models = [{ id: 'm1', name: 'GPT-5' }];
      mockGetModelsByIndustry.mockResolvedValue(models);

      const result = await service.getModels('finance');

      expect(mockGetModelsByIndustry).toHaveBeenCalledWith('finance');
      expect(result).toEqual(models);
    });
  });

  describe('getAgents', () => {
    it('delegates to the agents repository', async () => {
      const agents = [{ id: 'a1', name: 'TradingBot' }];
      mockGetAgentsByIndustry.mockResolvedValue(agents);

      const result = await service.getAgents('finance');

      expect(mockGetAgentsByIndustry).toHaveBeenCalledWith('finance');
      expect(result).toEqual(agents);
    });
  });

  describe('getApps', () => {
    it('delegates to the apps repository', async () => {
      const apps = [{ id: 'app1', name: 'FinanceApp' }];
      mockGetAppsByIndustry.mockResolvedValue(apps);

      const result = await service.getApps('finance');

      expect(mockGetAppsByIndustry).toHaveBeenCalledWith('finance');
      expect(result).toEqual(apps);
    });
  });
});
