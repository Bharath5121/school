import { DashboardService } from '../services/dashboard.service';

describe('DashboardService', () => {
  let service: DashboardService;

  beforeEach(() => {
    jest.clearAllMocks();
    service = new DashboardService();
  });

  describe('getStudentSummary', () => {
    const userId = 'user-1';

    const mockUser = {
      name: 'Alice',
      profile: {
        gradeLevel: '10th',
        interests: [{ fieldName: 'healthcare' }, { fieldName: 'finance' }],
      },
    };

    const mockTrending = [
      { id: 't1', title: 'AI in Surgery', views: 100 },
      { id: 't2', title: 'GPT-5 Launch', views: 80 },
    ];

    const mockRecentFeed = [
      {
        id: 'f1',
        title: 'Top Story',
        contentType: 'article',
        fieldSlug: 'healthcare',
        summary: 'Big news',
        careerImpactText: 'High impact',
        publishedAt: new Date(),
      },
      {
        id: 'f2',
        title: 'Second Story',
        contentType: 'model',
        fieldSlug: 'finance',
        summary: 'Finance AI',
        careerImpactText: null,
        publishedAt: new Date(),
      },
    ];

    it('returns aggregated homepage data', async () => {
      mockUserFindUnique.mockResolvedValue(mockUser);
      mockFeedItemFindMany
        .mockResolvedValueOnce(mockTrending)
        .mockResolvedValueOnce(mockRecentFeed)
        .mockResolvedValueOnce([{ id: 'hc1', title: 'Health AI', contentType: 'article', fieldSlug: 'healthcare' }])
        .mockResolvedValueOnce([]);

      const result = await service.getStudentSummary(userId);

      expect(result.user).toEqual({
        name: 'Alice',
        interests: ['healthcare', 'finance'],
        gradeLevel: '10th',
      });
      expect(result.trending).toHaveLength(2);
      expect(result.trending[0]).toMatchObject({ id: 't1', title: 'AI in Surgery', views: 100 });
      expect(result.topStory).toMatchObject({
        id: 'f1',
        title: 'Top Story',
        field: 'healthcare',
      });
      expect(result.recentFeed).toHaveLength(2);
      expect(result.fieldFeeds.healthcare).toHaveLength(1);
      expect(result.fieldFeeds.finance).toBeUndefined();
    });

    it('returns empty state gracefully when user has no profile', async () => {
      mockUserFindUnique.mockResolvedValue(null);
      mockFeedItemFindMany
        .mockResolvedValueOnce([])
        .mockResolvedValueOnce([]);

      const result = await service.getStudentSummary(userId);

      expect(result.user).toEqual({
        name: 'Student',
        interests: [],
        gradeLevel: null,
      });
      expect(result.trending).toEqual([]);
      expect(result.topStory).toBeNull();
      expect(result.recentFeed).toEqual([]);
      expect(result.fieldFeeds).toEqual({});
    });

    it('returns correct topStory from the first recent feed item', async () => {
      mockUserFindUnique.mockResolvedValue({
        name: 'Bob',
        profile: { gradeLevel: '8th', interests: [] },
      });
      const topItem = {
        id: 'top-1',
        title: 'Breaking News',
        contentType: 'model',
        fieldSlug: 'tech',
        summary: 'New model released',
        careerImpactText: null,
        publishedAt: new Date(),
      };
      mockFeedItemFindMany
        .mockResolvedValueOnce([])
        .mockResolvedValueOnce([topItem]);

      const result = await service.getStudentSummary(userId);

      expect(result.topStory).toEqual({
        id: 'top-1',
        title: 'Breaking News',
        field: 'tech',
        type: 'model',
        summary: 'New model released',
      });
    });

    it('skips field feeds when interest returns no items', async () => {
      mockUserFindUnique.mockResolvedValue({
        name: 'Charlie',
        profile: { gradeLevel: null, interests: [{ fieldName: 'robotics' }] },
      });
      mockFeedItemFindMany
        .mockResolvedValueOnce([])
        .mockResolvedValueOnce([])
        .mockResolvedValueOnce([]);

      const result = await service.getStudentSummary(userId);

      expect(result.fieldFeeds).toEqual({});
      expect(result.user.interests).toEqual(['robotics']);
    });
  });
});
