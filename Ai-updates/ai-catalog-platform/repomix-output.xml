  it('should call next with 403 for TEACHER role', () => {
    const { req, res, next } = mockReqResNext();
    req.user = { userId: 'teacher-1', role: 'TEACHER' };

    requireAdmin(req, res, next);

    expect(next).toHaveBeenCalledWith(expect.any(AppError));
