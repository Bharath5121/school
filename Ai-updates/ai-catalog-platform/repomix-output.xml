  });

  it('shows Next Screen button on step 1', () => {
    render(<OnboardingFlow />);
    expect(screen.getByText('Next Screen')).toBeInTheDocument();
  });

  it('does not show Back button on step 1', () => {
    render(<OnboardingFlow />);
    expect(screen.queryByText('Back')).not.toBeInTheDocument();
  });

  it('calls nextStep when Next Screen is clicked', () => {
    render(<OnboardingFlow />);
    fireEvent.click(screen.getByText('Next Screen'));
    expect(mockNextStep).toHaveBeenCalledOnce();
  });

  it('disables Next Screen when step is not valid', () => {
    controllerOverride = { ...defaultController, isStepValid: false };

    render(<OnboardingFlow />);
    expect(screen.getByText('Next Screen')).toBeDisabled();
  });

  it('renders step 2 with Back button', () => {
    controllerOverride = { ...defaultController, step: 2 };

    render(<OnboardingFlow />);

    expect(screen.getByTestId('step2')).toBeInTheDocument();
    expect(screen.queryByTestId('step1')).not.toBeInTheDocument();
    expect(screen.getByText('Back')).toBeInTheDocument();
    expect(screen.getByText('Step 2 of 3')).toBeInTheDocument();
  });

  it('calls prevStep when Back is clicked', () => {
    controllerOverride = { ...defaultController, step: 2 };

    render(<OnboardingFlow />);
    fireEvent.click(screen.getByText('Back'));
    expect(mockPrevStep).toHaveBeenCalledOnce();
  });

  it('renders step 3 with completion button', () => {
    controllerOverride = { ...defaultController, step: 3 };

    render(<OnboardingFlow />);

    expect(screen.getByTestId('step3')).toBeInTheDocument();
    expect(screen.getByText('Take me to my Dashboard')).toBeInTheDocument();
    expect(screen.queryByText('Next Screen')).not.toBeInTheDocument();
  });

  it('calls handleComplete on final step button click', () => {
    controllerOverride = { ...defaultController, step: 3 };

    render(<OnboardingFlow />);
    fireEvent.click(screen.getByText('Take me to my Dashboard'));
    expect(mockHandleComplete).toHaveBeenCalledOnce();
  });

  it('shows loading text when completing', () => {
    controllerOverride = { ...defaultController, step: 3, loading: true };

    render(<OnboardingFlow />);
    expect(screen.getByText('Finalizing...')).toBeInTheDocument();
  });
