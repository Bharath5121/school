import React from 'react';

const mockNextStep = vi.fn();
const mockPrevStep = vi.fn();
const mockUpdateFormData = vi.fn();
const mockHandleComplete = vi.fn();

const defaultController = {
  step: 1,
  loading: false,
  formData: {},
  nextStep: mockNextStep,
  prevStep: mockPrevStep,
  updateFormData: mockUpdateFormData,
  handleComplete: mockHandleComplete,
  isStepValid: true,
};

let controllerOverride = { ...defaultController };

vi.mock('@/features/onboarding/controllers/onboarding.controller', () => ({
  useOnboardingController: () => controllerOverride,
}));

vi.mock('@/features/onboarding/components/Step1Who', () => ({
