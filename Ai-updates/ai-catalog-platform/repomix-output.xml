'use client';

import { useState, useEffect } from 'react';
import { Plus, Trash2, GripVertical, ChevronUp, ChevronDown } from 'lucide-react';
import { adminApi } from '@/features/admin/services/admin.api';
import { AdminFormModal } from '@/features/admin/components/AdminFormModal';
import type { Guide, PromptTemplate } from '@/types/admin.types';

interface GuideStep {
  step: number;
  title: string;
  content: string;
}

interface GuideFormData {
  title: string;
  description: string;
  difficulty: string;
  timeRequired: string;
  toolsNeeded: string[];
  whatYouLearn: string;
  isPublished: boolean;
  industrySlug: string;
  steps: GuideStep[];
}

interface PromptFormData {
  title: string;
  promptText: string;
  useCase: string;
  category: string;
  industrySlug: string;
}

const EMPTY_STEP: GuideStep = { step: 1, title: '', content: '' };

const GUIDE_FORM: GuideFormData = {
  title: '', description: '', difficulty: 'BEGINNER', timeRequired: '',
  toolsNeeded: [], whatYouLearn: '', isPublished: true, industrySlug: '', steps: [],
};

const PROMPT_FORM: PromptFormData = {
  title: '', promptText: '', useCase: '', category: '', industrySlug: '',
};

const DIFFICULTY_OPTIONS = [
  { value: 'BEGINNER', label: 'Beginner' },
  { value: 'INTERMEDIATE', label: 'Intermediate' },
  { value: 'ADVANCED', label: 'Advanced' },
];

interface GuideFormDialogProps {
  editing: Guide | null;
  industryOptions: { value: string; label: string }[];
  onClose: () => void;
  onSaved: () => void;
}

export function GuideFormDialog({ editing, industryOptions, onClose, onSaved }: GuideFormDialogProps) {
  const [guideForm, setGuideForm] = useState<GuideFormData>({ ...GUIDE_FORM });
  const [saving, setSaving] = useState(false);

  useEffect(() => {
    if (editing) {
      const existingSteps = Array.isArray(editing.steps)
        ? (editing.steps as GuideStep[]).map((s, i) => ({
            step: s.step ?? i + 1, title: s.title ?? '', content: s.content ?? '',
          }))
        : [];
      setGuideForm({
        title: editing.title ?? '', description: editing.description ?? '',
        difficulty: editing.difficulty ?? 'BEGINNER', timeRequired: editing.timeRequired ?? '',
        toolsNeeded: Array.isArray(editing.toolsNeeded) ? editing.toolsNeeded : [],
        whatYouLearn: editing.whatYouLearn ?? '', isPublished: editing.isPublished ?? true,
        industrySlug: editing.industrySlug ?? '', steps: existingSteps,
      });
    } else {
      setGuideForm({ ...GUIDE_FORM });
    }
  }, [editing]);

  const handleSubmit = async () => {
    setSaving(true);
    try {
      const payload = {
        title: guideForm.title, description: guideForm.description, difficulty: guideForm.difficulty,
        timeRequired: guideForm.timeRequired, toolsNeeded: guideForm.toolsNeeded,
        whatYouLearn: guideForm.whatYouLearn, isPublished: !!guideForm.isPublished,
        industrySlug: guideForm.industrySlug,
        steps: guideForm.steps.filter((s) => s.title.trim()).map((s, i) => ({ step: i + 1, title: s.title, content: s.content })),
      };
      if (editing) { await adminApi.updateGuide(editing.id, payload); }
      else { await adminApi.createGuide(payload); }
      onSaved();
      onClose();
    } catch (err) { alert((err as Error).message); }
    finally { setSaving(false); }
  };

  const steps = guideForm.steps;

  const addStep = () => {
    setGuideForm(p => ({ ...p, steps: [...p.steps, { ...EMPTY_STEP, step: p.steps.length + 1 }] }));
  };
  const removeStep = (idx: number) => {
    setGuideForm(p => ({
      ...p,
      steps: p.steps.filter((_, i) => i !== idx).map((s, i) => ({ ...s, step: i + 1 })),
    }));
  };
  const updateStep = (idx: number, field: 'title' | 'content', value: string) => {
    setGuideForm(p => ({
      ...p,
      steps: p.steps.map((s, i) => i === idx ? { ...s, [field]: value } : s),
    }));
  };
  const moveStep = (idx: number, dir: -1 | 1) => {
    const target = idx + dir;
    if (target < 0 || target >= steps.length) return;
    setGuideForm(p => {
      const arr = [...p.steps];
      [arr[idx], arr[target]] = [arr[target], arr[idx]];
      return { ...p, steps: arr.map((s, i) => ({ ...s, step: i + 1 })) };
    });
  };

  const guideFields = [
    { key: 'title', label: 'Title', type: 'text' as const, required: true },
    { key: 'description', label: 'Description', type: 'textarea' as const },
    { key: 'industrySlug', label: 'Industry', type: 'select' as const, required: true, options: industryOptions },
    { key: 'difficulty', label: 'Difficulty', type: 'select' as const, options: DIFFICULTY_OPTIONS },
    { key: 'timeRequired', label: 'Time Required', type: 'text' as const, placeholder: 'e.g. 30 minutes' },
    { key: 'toolsNeeded', label: 'Tools Needed', type: 'tags' as const, placeholder: 'Comma separated' },
    { key: 'whatYouLearn', label: 'What You Learn', type: 'textarea' as const },
    { key: 'isPublished', label: 'Published', type: 'boolean' as const },
  ];

  return (
    <AdminFormModal title={editing ? 'Edit Guide' : 'Add Guide'} fields={guideFields} data={guideForm}
      onChange={(k, v) => setGuideForm(p => ({ ...p, [k]: v } as GuideFormData))} onSubmit={handleSubmit} onClose={onClose} loading={saving}>
      <div className="mt-4 pt-4 border-t border-slate-200 dark:border-slate-700/30">
        <div className="flex items-center justify-between mb-3">
          <label className="text-xs font-medium text-slate-500 dark:text-slate-400">Steps</label>
          <button type="button" onClick={addStep}
            className="flex items-center gap-1 text-xs font-medium text-emerald-600 dark:text-emerald-400 hover:text-emerald-500 transition-colors">
            <Plus size={14} /> Add Step
          </button>
        </div>
        {steps.length === 0 && (
          <p className="text-xs text-slate-400 dark:text-slate-500 text-center py-4">No steps yet. Click &quot;Add Step&quot; to start building.</p>
        )}
        <div className="space-y-3">
          {steps.map((s, idx) => (
            <div key={idx} className="p-3 rounded-lg border border-slate-200 dark:border-slate-700/40 bg-slate-50 dark:bg-slate-800/30 space-y-2">
              <div className="flex items-center gap-2">
                <GripVertical size={14} className="text-slate-400 flex-shrink-0" />
                <span className="text-xs font-bold text-slate-500 dark:text-slate-400 w-6 flex-shrink-0">#{s.step}</span>
                <input type="text" value={s.title} onChange={e => updateStep(idx, 'title', e.target.value)}
                  placeholder="Step title"
                  className="flex-1 rounded-lg border border-slate-200 dark:border-slate-700/40 bg-white dark:bg-[#0B0F19] px-2 py-1.5 text-sm text-gray-900 dark:text-white placeholder:text-slate-400 focus:outline-none focus:border-emerald-500/40 focus:ring-1 focus:ring-emerald-500/20" />
                <button type="button" onClick={() => moveStep(idx, -1)} disabled={idx === 0}
                  className="p-1 rounded hover:bg-slate-200 dark:hover:bg-slate-700/50 text-slate-400 disabled:opacity-30 transition-colors"><ChevronUp size={14} /></button>
                <button type="button" onClick={() => moveStep(idx, 1)} disabled={idx === steps.length - 1}
                  className="p-1 rounded hover:bg-slate-200 dark:hover:bg-slate-700/50 text-slate-400 disabled:opacity-30 transition-colors"><ChevronDown size={14} /></button>
                <button type="button" onClick={() => removeStep(idx)}
                  className="p-1 rounded hover:bg-rose-50 dark:hover:bg-rose-500/10 text-slate-400 hover:text-rose-500 transition-colors"><Trash2 size={14} /></button>
              </div>
              <textarea value={s.content} onChange={e => updateStep(idx, 'content', e.target.value)}
                placeholder="Step content / instructions"
                className="w-full rounded-lg border border-slate-200 dark:border-slate-700/40 bg-white dark:bg-[#0B0F19] px-2 py-1.5 text-sm text-gray-900 dark:text-white placeholder:text-slate-400 focus:outline-none focus:border-emerald-500/40 focus:ring-1 focus:ring-emerald-500/20 min-h-[60px] resize-y" />
            </div>
          ))}
        </div>
      </div>
    </AdminFormModal>
  );
}

interface PromptFormDialogProps {
  editing: PromptTemplate | null;
  industryOptions: { value: string; label: string }[];
  onClose: () => void;
  onSaved: () => void;
}

export function PromptFormDialog({ editing, industryOptions, onClose, onSaved }: PromptFormDialogProps) {
  const [promptForm, setPromptForm] = useState<PromptFormData>({ ...PROMPT_FORM });
  const [saving, setSaving] = useState(false);

  useEffect(() => {
    if (editing) {
      setPromptForm({
        title: editing.title ?? '', promptText: editing.prompt ?? '',
        useCase: editing.useCase ?? '', category: editing.category ?? '',
        industrySlug: editing.industrySlug ?? '',
      });
    } else {
      setPromptForm({ ...PROMPT_FORM });
    }
  }, [editing]);

  const handleSubmit = async () => {
    setSaving(true);
    try {
      const payload = {
        title: promptForm.title, promptText: promptForm.promptText,
        useCase: promptForm.useCase, category: promptForm.category,
        industrySlug: promptForm.industrySlug,
      };
      if (editing) { await adminApi.updatePrompt(editing.id, payload); }
      else { await adminApi.createPrompt(payload); }
      onSaved();
      onClose();
    } catch (err) { alert((err as Error).message); }
    finally { setSaving(false); }
  };

  const promptFields = [
    { key: 'title', label: 'Title', type: 'text' as const, required: true },
    { key: 'promptText', label: 'Prompt Text', type: 'textarea' as const, required: true },
    { key: 'useCase', label: 'Use Case', type: 'text' as const },
    { key: 'category', label: 'Category', type: 'text' as const },
    { key: 'industrySlug', label: 'Industry', type: 'select' as const, required: true, options: industryOptions },
  ];

  return (
    <AdminFormModal title={editing ? 'Edit Prompt' : 'Add Prompt'} fields={promptFields} data={promptForm}
      onChange={(k, v) => setPromptForm(p => ({ ...p, [k]: v } as PromptFormData))} onSubmit={handleSubmit} onClose={onClose} loading={saving} />
  );
}
