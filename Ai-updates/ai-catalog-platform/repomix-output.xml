'use client';

import { useState, useEffect } from 'react';
import { adminApi } from '@/features/admin/services/admin.api';
import { AdminFormModal } from '@/features/admin/components/AdminFormModal';
import type { CareerPath, CareerJob } from '@/types/admin.types';

const PATH_FORM: Partial<CareerPath> = {
  title: '', description: '', aiImpactSummary: '', industrySlug: '', sortOrder: 0,
};

const JOB_FORM: Partial<CareerJob> = {
  title: '', salaryRangeMin: 0, salaryRangeMax: 0, currency: 'USD', demand: 'GROWING',
  requiredDegree: '', requiredSkills: [], futureSkills: [], howAiChanges: '',
  googleUrl: '', notebookLmUrl: '', timeline: 'NOW', sortOrder: 0, careerPathId: '',
};

const DEMAND_OPTIONS = [
  { value: 'GROWING', label: 'Growing' },
  { value: 'STABLE', label: 'Stable' },
  { value: 'AT_RISK', label: 'At Risk' },
];

const TIMELINE_OPTIONS = [
  { value: 'NOW', label: 'Today' },
  { value: 'YEAR_2030', label: '2030' },
  { value: 'FUTURE', label: 'Future' },
];

interface PathFormDialogProps {
  editing: CareerPath | null;
  industryOptions: { value: string; label: string }[];
  onClose: () => void;
  onSaved: () => void;
}

export function PathFormDialog({ editing, industryOptions, onClose, onSaved }: PathFormDialogProps) {
  const [pathForm, setPathForm] = useState<Partial<CareerPath>>(PATH_FORM);
  const [saving, setSaving] = useState(false);

  useEffect(() => {
    if (editing) {
      setPathForm({
        title: editing.title ?? '', description: editing.description ?? '',
        aiImpactSummary: editing.aiImpactSummary ?? '', industrySlug: editing.industrySlug ?? '',
        sortOrder: editing.sortOrder ?? 0,
      });
    } else {
      setPathForm({ ...PATH_FORM });
    }
  }, [editing]);

  const handleSubmit = async () => {
    setSaving(true);
    try {
      const payload: Partial<CareerPath> = {
        title: pathForm.title, description: pathForm.description,
        aiImpactSummary: pathForm.aiImpactSummary, industrySlug: pathForm.industrySlug,
        sortOrder: Number(pathForm.sortOrder) || 0,
      };
      if (editing) { await adminApi.updateCareerPath(editing.id, payload); }
      else { await adminApi.createCareerPath(payload); }
      onSaved();
      onClose();
    } catch (err) { alert((err as Error).message); }
    finally { setSaving(false); }
  };

  const pathFields = [
    { key: 'title', label: 'Title', type: 'text' as const, required: true },
    { key: 'description', label: 'Description', type: 'textarea' as const },
    { key: 'aiImpactSummary', label: 'AI Impact Summary', type: 'textarea' as const },
    { key: 'industrySlug', label: 'Industry', type: 'select' as const, required: true, options: industryOptions },
    { key: 'sortOrder', label: 'Sort Order', type: 'text' as const },
  ];

  return (
    <AdminFormModal title={editing ? 'Edit Career Path' : 'Add Career Path'} fields={pathFields} data={pathForm}
      onChange={(k, v) => setPathForm(p => ({ ...p, [k]: v } as Partial<CareerPath>))} onSubmit={handleSubmit} onClose={onClose} loading={saving} />
  );
}

interface JobFormDialogProps {
  editing: CareerJob | null;
  pathOptions: { value: string; label: string }[];
  onClose: () => void;
  onSaved: () => void;
}

export function JobFormDialog({ editing, pathOptions, onClose, onSaved }: JobFormDialogProps) {
  const [jobForm, setJobForm] = useState<Partial<CareerJob>>(JOB_FORM);
  const [saving, setSaving] = useState(false);

  useEffect(() => {
    if (editing) {
      setJobForm({
        title: editing.title ?? '', salaryRangeMin: editing.salaryRangeMin ?? 0,
        salaryRangeMax: editing.salaryRangeMax ?? 0, currency: editing.currency ?? 'USD',
        demand: editing.demand ?? 'GROWING', requiredDegree: editing.requiredDegree ?? '',
        requiredSkills: Array.isArray(editing.requiredSkills) ? editing.requiredSkills : [],
        futureSkills: Array.isArray(editing.futureSkills) ? editing.futureSkills : [],
        howAiChanges: editing.howAiChanges ?? '', googleUrl: editing.googleUrl ?? '',
        notebookLmUrl: editing.notebookLmUrl ?? '', timeline: editing.timeline ?? 'NOW',
        sortOrder: editing.sortOrder ?? 0, careerPathId: editing.careerPathId ?? '',
      });
    } else {
      setJobForm({ ...JOB_FORM });
    }
  }, [editing]);

  const handleSubmit = async () => {
    setSaving(true);
    try {
      const payload: Partial<CareerJob> = {
        title: jobForm.title, salaryRangeMin: Number(jobForm.salaryRangeMin),
        salaryRangeMax: Number(jobForm.salaryRangeMax), currency: jobForm.currency || 'USD',
        demand: jobForm.demand, requiredDegree: jobForm.requiredDegree,
        requiredSkills: Array.isArray(jobForm.requiredSkills) ? jobForm.requiredSkills : [],
        futureSkills: Array.isArray(jobForm.futureSkills) ? jobForm.futureSkills : [],
        howAiChanges: jobForm.howAiChanges, googleUrl: jobForm.googleUrl || undefined,
        notebookLmUrl: jobForm.notebookLmUrl || undefined, timeline: jobForm.timeline,
        sortOrder: Number(jobForm.sortOrder) || 0, careerPathId: jobForm.careerPathId,
      };
      if (editing) { await adminApi.updateCareerJob(editing.id, payload); }
      else { await adminApi.createCareerJob(payload); }
      onSaved();
      onClose();
    } catch (err) { alert((err as Error).message); }
    finally { setSaving(false); }
  };

  const jobFields = [
    { key: 'title', label: 'Job Title', type: 'text' as const, required: true },
    { key: 'careerPathId', label: 'Career Path', type: 'select' as const, required: true, options: pathOptions },
    { key: 'salaryRangeMin', label: 'Salary Min ($)', type: 'text' as const },
    { key: 'salaryRangeMax', label: 'Salary Max ($)', type: 'text' as const },
    { key: 'currency', label: 'Currency', type: 'text' as const },
    { key: 'demand', label: 'Demand', type: 'select' as const, options: DEMAND_OPTIONS },
    { key: 'timeline', label: 'Timeline', type: 'select' as const, options: TIMELINE_OPTIONS },
    { key: 'requiredDegree', label: 'Required Degree', type: 'text' as const },
    { key: 'requiredSkills', label: 'Required Skills', type: 'tags' as const, placeholder: 'Comma separated' },
    { key: 'futureSkills', label: 'Future Skills', type: 'tags' as const, placeholder: 'Comma separated' },
    { key: 'howAiChanges', label: 'How AI Changes This Role', type: 'textarea' as const },
    { key: 'googleUrl', label: 'Google Link', type: 'url' as const, placeholder: 'Link to Google resource' },
    { key: 'notebookLmUrl', label: 'NotebookLM URL', type: 'url' as const, placeholder: 'Link to NotebookLM resource' },
    { key: 'sortOrder', label: 'Sort Order', type: 'text' as const },
  ];

  return (
    <AdminFormModal title={editing ? 'Edit Job' : 'Add Job'} fields={jobFields} data={jobForm}
      onChange={(k, v) => setJobForm(p => ({ ...p, [k]: v } as Partial<CareerJob>))} onSubmit={handleSubmit} onClose={onClose} loading={saving} />
  );
}
