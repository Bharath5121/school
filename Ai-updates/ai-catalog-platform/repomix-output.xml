jest.mock('../repositories/agents.repository', () => ({
  AgentsRepository: jest.fn().mockImplementation(() => ({
    getByIndustry: mockGetAgentsByIndustry,
  })),
}));

jest.mock('../repositories/apps.repository', () => ({
  AppsRepository: jest.fn().mockImplementation(() => ({
    getByIndustry: mockGetAppsByIndustry,
  })),
