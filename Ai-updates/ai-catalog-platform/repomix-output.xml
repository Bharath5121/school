import { NotebookService } from '../services/notebook.service';
import * as anythingllm from '../../../lib/anythingllm';

const mockAnythingllm = anythingllm as jest.Mocked<typeof anythingllm>;

describe('NotebookService', () => {
  let service: NotebookService;

  beforeEach(() => {
    jest.clearAllMocks();
    service = new NotebookService();
  });

  describe('getAllNotebooks', () => {
    it('returns all notebooks', async () => {
      const notebooks = [
        { id: '1', title: 'AI Basics', industrySlug: 'tech' },
        { id: '2', title: 'ML Intro', industrySlug: 'data' },
      ];
      mockFindAll.mockResolvedValue(notebooks);

      const result = await service.getAllNotebooks();

      expect(mockFindAll).toHaveBeenCalledWith(undefined);
      expect(result).toEqual(notebooks);
    });

    it('filters by industrySlug when provided', async () => {
      mockFindAll.mockResolvedValue([]);
      await service.getAllNotebooks('healthcare');
      expect(mockFindAll).toHaveBeenCalledWith('healthcare');
    });

    it('returns empty array when no notebooks exist', async () => {
      mockFindAll.mockResolvedValue([]);
      const result = await service.getAllNotebooks();
      expect(result).toEqual([]);
    });
  });

  describe('getNotebookById', () => {
    it('returns notebook when found', async () => {
      const notebook = { id: 'nb-1', title: 'AI Basics', published: true };
      mockFindById.mockResolvedValue(notebook);

      const result = await service.getNotebookById('nb-1');

      expect(mockFindById).toHaveBeenCalledWith('nb-1');
      expect(result).toEqual(notebook);
    });

    it('throws 404 when notebook not found', async () => {
      mockFindById.mockResolvedValue(null);

      await expect(service.getNotebookById('missing')).rejects.toThrow(AppError);
      await expect(service.getNotebookById('missing')).rejects.toMatchObject({
        statusCode: 404,
        message: 'Notebook not found',
      });
    });
  });

  describe('sendChat', () => {
    const userId = 'user-1';
    const notebookId = 'nb-1';
    const publishedNotebook = {
      id: notebookId,
      published: true,
      workspaceSlug: 'ws-slug',
    };

    it('sends a chat message and returns the AI response', async () => {
      mockFindById.mockResolvedValue(publishedNotebook);
      mockLogAccess.mockResolvedValue({});
      mockAnythingllm.sendChat.mockResolvedValue({
        text: 'AI says hello',
        sources: [{ title: 'Source 1' }],
      } as any);
      mockSaveChatMessage.mockResolvedValue({});

      const result = await service.sendChat(userId, notebookId, 'Hello AI');

      expect(mockLogAccess).toHaveBeenCalledWith(userId, notebookId);
      expect(mockAnythingllm.sendChat).toHaveBeenCalledWith('ws-slug', 'Hello AI', userId);
      expect(mockSaveChatMessage).toHaveBeenCalledWith({
        userId,
        notebookId,
        workspaceSlug: 'ws-slug',
        message: 'Hello AI',
        response: 'AI says hello',
      });
      expect(result).toEqual({ text: 'AI says hello', sources: [{ title: 'Source 1' }] });
    });

    it('throws 404 when notebook is not published', async () => {
      mockFindById.mockResolvedValue({ ...publishedNotebook, published: false });

      await expect(service.sendChat(userId, notebookId, 'Hi')).rejects.toMatchObject({
        statusCode: 404,
      });
    });

    it('throws 400 when notebook has no workspace', async () => {
      mockFindById.mockResolvedValue({ ...publishedNotebook, workspaceSlug: null });

      await expect(service.sendChat(userId, notebookId, 'Hi')).rejects.toMatchObject({
        statusCode: 400,
      });
    });

    it('throws 500 when AI returns an error', async () => {
      mockFindById.mockResolvedValue(publishedNotebook);
      mockLogAccess.mockResolvedValue({});
      mockAnythingllm.sendChat.mockResolvedValue({ text: '', sources: [], error: 'Model overloaded' } as any);

      await expect(service.sendChat(userId, notebookId, 'Hi')).rejects.toMatchObject({
        statusCode: 500,
      });
    });
  });

  describe('getChatHistory', () => {
    it('returns chat history for a user and notebook', async () => {
      const history = [
        { id: 'msg-1', message: 'Hello', response: 'Hi there', createdAt: new Date() },
      ];
      mockFindById.mockResolvedValue({ id: 'nb-1' });
      mockGetChatHistory.mockResolvedValue(history);

      const result = await service.getChatHistory('user-1', 'nb-1');

      expect(mockGetChatHistory).toHaveBeenCalledWith('user-1', 'nb-1');
      expect(result).toEqual(history);
    });

    it('throws 404 when notebook does not exist', async () => {
      mockFindById.mockResolvedValue(null);

      await expect(service.getChatHistory('user-1', 'missing')).rejects.toMatchObject({
        statusCode: 404,
      });
    });
  });

  describe('clearChatHistory', () => {
    it('clears history and returns confirmation', async () => {
      mockFindById.mockResolvedValue({ id: 'nb-1' });
      mockClearChatHistory.mockResolvedValue({ count: 5 });

      const result = await service.clearChatHistory('user-1', 'nb-1');

      expect(mockClearChatHistory).toHaveBeenCalledWith('user-1', 'nb-1');
      expect(result).toEqual({ cleared: true });
    });
  });

  describe('getNotebookAccess', () => {
    it('returns notebook access info for a free user within daily limit', async () => {
      const notebook = {
        id: 'nb-1',
        title: 'AI Basics',
        description: 'Learn AI',
        industrySlug: 'tech',
        workspaceSlug: 'ws-1',
        industry: { name: 'Technology' },
      };
      mockFindPublishedByCategory.mockResolvedValue([notebook]);
      mockCountUserAccessToday.mockResolvedValue(2);
      mockLogAccess.mockResolvedValue({});

      const result = await service.getNotebookAccess('user-1', 'tech', 'BASICS', false);

      expect(result).toMatchObject({
        notebookId: 'nb-1',
        title: 'AI Basics',
        industryName: 'Technology',
      });
    });

    it('throws 429 when free user exceeds daily limit', async () => {
      const notebook = {
        id: 'nb-1',
        industrySlug: 'tech',
        workspaceSlug: 'ws-1',
        industry: { name: 'Tech' },
      };
      mockFindPublishedByCategory.mockResolvedValue([notebook]);
      mockCountUserAccessToday.mockResolvedValue(5);

      await expect(
        service.getNotebookAccess('user-1', 'tech', 'BASICS', false),
      ).rejects.toMatchObject({ statusCode: 429 });
    });

    it('allows premium user to bypass daily limit', async () => {
      const notebook = {
        id: 'nb-1',
        title: 'AI Basics',
        description: 'desc',
        industrySlug: 'tech',
        workspaceSlug: 'ws-1',
        industry: { name: 'Technology' },
      };
      mockFindPublishedByCategory.mockResolvedValue([notebook]);
      mockLogAccess.mockResolvedValue({});

      const result = await service.getNotebookAccess('user-1', 'tech', 'BASICS', true);

      expect(mockCountUserAccessToday).not.toHaveBeenCalled();
      expect(result.notebookId).toBe('nb-1');
    });

    it('throws 404 when no published notebook matches the industry', async () => {
      mockFindPublishedByCategory.mockResolvedValue([]);

      await expect(
        service.getNotebookAccess('user-1', 'unknown', 'BASICS'),
      ).rejects.toMatchObject({ statusCode: 404 });
    });
  });
});
