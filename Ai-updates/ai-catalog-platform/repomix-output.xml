jest.mock('../repositories/auth.repository');
jest.mock('bcryptjs');
jest.mock('jsonwebtoken');
jest.mock('crypto', () => ({
  randomBytes: jest.fn(() => ({ toString: () => 'mock-refresh-token' })),
}));
jest.mock('../../../config/env', () => ({
  env: {
    JWT_SECRET: 'test-jwt-secret-that-is-32-chars-long',
    JWT_EXPIRES_IN: '15m',
    NODE_ENV: 'test',
