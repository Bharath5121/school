      mockAdd.mockResolvedValue(created);

      const result = await service.add('u1', data);

      expect(mockAdd).toHaveBeenCalledWith('u1', data);
      expect(result).toEqual(created);
    });

    it('handles duplicate bookmark gracefully via upsert', async () => {
      const data = { contentType: 'model', contentId: 'c1', title: 'GPT-5 Updated' };
      const upserted = { id: 'b1', userId: 'u1', ...data };
      mockAdd.mockResolvedValue(upserted);

