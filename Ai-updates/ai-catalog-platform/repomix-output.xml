<file path="frontend/apps/admin/src/features/dashboard/services/admin.api.ts">
import { useAppStore } from '@/store/app.store';
import { API_URL } from '@/lib/config';
import type {
  ContentStats,
  DashboardSummary,
  Industry,
  AIModel,
  AIAgent,
  AIApp,
  PredefinedQuestion,
  BasicsTopic,
  BasicsVideo,
  BasicsArticle,
  CareerPath,
  CareerJob,
  Skill,
  Guide,
  PromptTemplate,
  MasterNotebook,
  NotebookSource,
  User,
} from '@/types/admin.types';

function getHeaders(): HeadersInit {
  const token = useAppStore.getState().accessToken;
  return {
    'Content-Type': 'application/json',
    ...(token ? { Authorization: `Bearer ${token}` } : {}),
  };
}

async function request<T>(url: string, options?: RequestInit): Promise<T> {
  const res = await fetch(`${API_URL}${url}`, {
    ...options,
    headers: { ...getHeaders(), ...options?.headers },
  });
  const json: { data: T; message?: string } = await res.json();
  if (!res.ok) throw new Error(json.message || 'Request failed');
  return json.data;
}

export const adminApi = {
  getContentStats: () => request<ContentStats>('/home/admin/stats'),
  getDashboard: () => request<DashboardSummary>('/admin/dashboard/summary'),

  getUsers: (page = 1, limit = 20, role?: string) => {
    const params = new URLSearchParams({ page: String(page), limit: String(limit) });
    if (role) params.set('role', role);
    return request<{ users: User[]; total: number }>(`/admin/users?${params}`);
  },
  getUser: (id: string) => request<User>(`/admin/users/${id}`),
  updateUserRole: (id: string, role: string) =>
    request<User>(`/admin/users/${id}/role`, { method: 'PUT', body: JSON.stringify({ role }) }),
  deleteUser: (id: string) =>
    request<void>(`/admin/users/${id}`, { method: 'DELETE' }),

  getIndustries: () => request<Industry[]>('/home/admin/industries'),
  createIndustry: (data: Partial<Industry>) =>
    request<Industry>('/home/admin/industries', { method: 'POST', body: JSON.stringify(data) }),
  updateIndustry: (id: string, data: Partial<Industry>) =>
    request<Industry>(`/home/admin/industries/${id}`, { method: 'PUT', body: JSON.stringify(data) }),
  deleteIndustry: (id: string) =>
    request<void>(`/home/admin/industries/${id}`, { method: 'DELETE' }),

  getModels: (industrySlug?: string) => {
    const params = industrySlug ? `?industrySlug=${industrySlug}` : '';
    return request<AIModel[]>(`/home/admin/models${params}`);
  },
  createModel: (data: Partial<AIModel>) =>
    request<AIModel>('/home/admin/models', { method: 'POST', body: JSON.stringify(data) }),
  updateModel: (id: string, data: Partial<AIModel>) =>
    request<AIModel>(`/home/admin/models/${id}`, { method: 'PUT', body: JSON.stringify(data) }),
  deleteModel: (id: string) =>
    request<void>(`/home/admin/models/${id}`, { method: 'DELETE' }),

  getAgents: (industrySlug?: string) => {
    const params = industrySlug ? `?industrySlug=${industrySlug}` : '';
    return request<AIAgent[]>(`/home/admin/agents${params}`);
  },
  createAgent: (data: Partial<AIAgent>) =>
    request<AIAgent>('/home/admin/agents', { method: 'POST', body: JSON.stringify(data) }),
  updateAgent: (id: string, data: Partial<AIAgent>) =>
    request<AIAgent>(`/home/admin/agents/${id}`, { method: 'PUT', body: JSON.stringify(data) }),
  deleteAgent: (id: string) =>
    request<void>(`/home/admin/agents/${id}`, { method: 'DELETE' }),

  getApps: (industrySlug?: string) => {
    const params = industrySlug ? `?industrySlug=${industrySlug}` : '';
    return request<AIApp[]>(`/home/admin/apps${params}`);
  },
  createApp: (data: Partial<AIApp>) =>
    request<AIApp>('/home/admin/apps', { method: 'POST', body: JSON.stringify(data) }),
  updateApp: (id: string, data: Partial<AIApp>) =>
    request<AIApp>(`/home/admin/apps/${id}`, { method: 'PUT', body: JSON.stringify(data) }),
  deleteApp: (id: string) =>
    request<void>(`/home/admin/apps/${id}`, { method: 'DELETE' }),

  getQuestions: (industrySlug?: string) => {
    const params = industrySlug ? `?industrySlug=${industrySlug}` : '';
    return request<PredefinedQuestion[]>(`/home/admin/questions${params}`);
  },
