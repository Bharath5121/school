import { ChildrenService } from '../services/children.service';
import { AppError } from '../../../shared/errors/AppError';

const service = new ChildrenService();

describe('ChildrenService', () => {
  describe('getLinkedChildren', () => {
    it('returns list of linked children for the parent', async () => {
      const children = [
        { id: 'c1', name: 'Alice', email: 'alice@test.com', gradeLevel: '5', linkedAt: new Date('2025-01-01') },
        { id: 'c2', name: 'Bob', email: 'bob@test.com', gradeLevel: '7', linkedAt: new Date('2025-02-01') },
      ];
      mockRepo.getLinkedChildren.mockResolvedValue(children);

      const result = await service.getLinkedChildren('parent-1');

      expect(result).toEqual(children);
      expect(result).toHaveLength(2);
      expect(mockRepo.getLinkedChildren).toHaveBeenCalledWith('parent-1');
    });

    it('returns empty array when no children are linked', async () => {
      mockRepo.getLinkedChildren.mockResolvedValue([]);

      const result = await service.getLinkedChildren('parent-no-kids');

      expect(result).toEqual([]);
      expect(mockRepo.getLinkedChildren).toHaveBeenCalledWith('parent-no-kids');
    });
  });

  describe('linkChild', () => {
    const student = { id: 'student-1', name: 'Alice', email: 'alice@test.com' };

    it('links a child and returns student info when student exists and not already linked', async () => {
      mockRepo.findStudentByNameAndEmail.mockResolvedValue(student);
      mockRepo.linkExists.mockResolvedValue(false);
      mockRepo.linkChild.mockResolvedValue(undefined);

      const result = await service.linkChild('parent-1', 'Alice', 'alice@test.com');

      expect(result).toEqual({ id: 'student-1', name: 'Alice', email: 'alice@test.com' });
      expect(mockRepo.findStudentByNameAndEmail).toHaveBeenCalledWith('Alice', 'alice@test.com');
      expect(mockRepo.linkExists).toHaveBeenCalledWith('parent-1', 'student-1');
      expect(mockRepo.linkChild).toHaveBeenCalledWith('parent-1', 'student-1');
    });

    it('throws 404 AppError when no student account found', async () => {
      mockRepo.findStudentByNameAndEmail.mockResolvedValue(null);

      try {
        await service.linkChild('parent-1', 'Ghost', 'ghost@test.com');
        fail('Expected AppError to be thrown');
      } catch (err) {
        expect(err).toBeInstanceOf(AppError);
        expect((err as AppError).statusCode).toBe(404);
        expect((err as AppError).message).toBe('No student account found with that name and email.');
      }

      expect(mockRepo.linkExists).not.toHaveBeenCalled();
      expect(mockRepo.linkChild).not.toHaveBeenCalled();
    });

    it('throws 409 AppError when child is already linked', async () => {
      mockRepo.findStudentByNameAndEmail.mockResolvedValue(student);
      mockRepo.linkExists.mockResolvedValue(true);

      try {
        await service.linkChild('parent-1', 'Alice', 'alice@test.com');
        fail('Expected AppError to be thrown');
      } catch (err) {
        expect(err).toBeInstanceOf(AppError);
        expect((err as AppError).statusCode).toBe(409);
        expect((err as AppError).message).toBe('This student is already linked to your account.');
      }

      expect(mockRepo.linkChild).not.toHaveBeenCalled();
    });
  });

  describe('unlinkChild', () => {
    it('unlinks a child when the link exists', async () => {
      mockRepo.linkExists.mockResolvedValue(true);
      mockRepo.unlinkChild.mockResolvedValue(undefined);

      await service.unlinkChild('parent-1', 'child-1');

      expect(mockRepo.linkExists).toHaveBeenCalledWith('parent-1', 'child-1');
      expect(mockRepo.unlinkChild).toHaveBeenCalledWith('parent-1', 'child-1');
    });

    it('throws 404 AppError when child is not linked to the parent', async () => {
      mockRepo.linkExists.mockResolvedValue(false);

      try {
        await service.unlinkChild('parent-1', 'unlinked-child');
        fail('Expected AppError to be thrown');
      } catch (err) {
        expect(err).toBeInstanceOf(AppError);
        expect((err as AppError).statusCode).toBe(404);
        expect((err as AppError).message).toBe('This student is not linked to your account.');
      }

      expect(mockRepo.unlinkChild).not.toHaveBeenCalled();
    });
  });
