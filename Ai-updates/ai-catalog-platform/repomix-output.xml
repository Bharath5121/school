'use client';

import { useEffect, useState, useCallback } from 'react';
import { ChevronDown, ChevronUp } from 'lucide-react';
import { adminApi } from '@/features/admin/services/admin.api';
import { AdminTable } from '@/features/admin/components/AdminTable';
import { TopicFormDialog, ResourcePanel } from './components/BasicsFormDialog';
import type { BasicsTopic } from '@/types/admin.types';

export default function BasicsPage() {
  const [topics, setTopics] = useState<BasicsTopic[]>([]);
  const [loading, setLoading] = useState(true);
  const [showForm, setShowForm] = useState(false);
  const [editing, setEditing] = useState<BasicsTopic | null>(null);
  const [expanded, setExpanded] = useState<string | null>(null);
  const [detailCache, setDetailCache] = useState<Record<string, BasicsTopic>>({});

  const fetchData = useCallback(async () => {
    setLoading(true);
    try {
      const data = await adminApi.getBasicsTopics();
      setTopics(data);
    } catch { /* empty */ }
    setLoading(false);
  }, []);

  useEffect(() => { fetchData(); }, [fetchData]);

  const loadDetail = async (id: string) => {
    if (detailCache[id]) return;
    try {
      const detail = await adminApi.getBasicsTopic(id);
      setDetailCache((prev) => ({ ...prev, [id]: detail }));
    } catch { /* empty */ }
  };

  const toggleExpand = (id: string) => {
    if (expanded === id) { setExpanded(null); }
    else { setExpanded(id); loadDetail(id); }
  };

  const handleAdd = () => { setEditing(null); setShowForm(true); };
  const handleEdit = (item: BasicsTopic) => { setEditing(item); setShowForm(true); };
  const handleDelete = async (item: BasicsTopic) => {
    if (!confirm(`Delete "${item.title}"?`)) return;
    try { await adminApi.deleteBasicsTopic(item.id); fetchData(); } catch { /* empty */ }
  };

  const handleResourceChanged = () => {
    if (expanded) {
      setDetailCache((prev) => { const n = { ...prev }; delete n[expanded]; return n; });
      loadDetail(expanded);
    }
  };

  const columns = [
    { key: 'title', label: 'Title' },
    { key: 'slug', label: 'Slug' },
    { key: 'color', label: 'Color' },
    { key: 'sortOrder', label: 'Order' },
    {
      key: 'id', label: 'Detail',
      render: (_: unknown, row: BasicsTopic) => (
        <button
          onClick={(e) => { e.stopPropagation(); toggleExpand(row.id); }}
          className="text-xs text-emerald-400 hover:underline flex items-center gap-1"
        >
          {expanded === row.id ? <ChevronUp size={12} /> : <ChevronDown size={12} />}
          {expanded === row.id ? 'Hide' : 'Videos & Articles'}
        </button>
      ),
    },
  ];

  return (
    <div>
      <AdminTable
        title="Basics Topics"
        columns={columns}
        data={topics}
        loading={loading}
        onAdd={handleAdd}
        onEdit={handleEdit}
        onDelete={handleDelete}
      />

      {expanded && detailCache[expanded] && (
        <ResourcePanel topic={detailCache[expanded]} onResourceChanged={handleResourceChanged} />
      )}

      {showForm && (
        <TopicFormDialog
          editing={editing}
          onClose={() => setShowForm(false)}
          onSaved={() => { setDetailCache({}); fetchData(); }}
        />
      )}
    </div>
  );
}
</file>

