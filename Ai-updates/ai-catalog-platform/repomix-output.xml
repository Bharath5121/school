  --text-secondary: #94A3B8;
  --text-muted: #64748B;
  --accent: #10B981;
  --accent-light: #34D399;
}

body {
  background-color: var(--bg-page);
  color: var(--text-primary);
  font-family: var(--font-dm-sans), sans-serif;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  transition: background-color 0.3s ease, color 0.3s ease;
}

@layer components {
  .section-standard { @apply py-24; }
  .container-standard { @apply max-w-[1200px] mx-auto px-6; }

  .card-surface {
    @apply bg-white dark:bg-[#111827]
           border border-gray-100 dark:border-slate-700/40
           rounded-2xl
           shadow-[0_1px_3px_rgba(0,0,0,0.04),0_1px_2px_rgba(0,0,0,0.02)] dark:shadow-none
           transition-all duration-300 ease-out;
  }

  .card-surface-hover {
    @apply hover:border-gray-200 dark:hover:border-slate-600/50
           hover:bg-white dark:hover:bg-[#151C2C]
           hover:shadow-[0_4px_16px_rgba(0,0,0,0.06),0_2px_4px_rgba(0,0,0,0.03)] dark:hover:shadow-black/30;
  }

  .card-interactive {
    @apply card-surface card-surface-hover
           hover:-translate-y-0.5;
  }

  .glow-emerald {
    box-shadow: 0 0 60px rgba(16, 185, 129, 0.08),
                0 0 120px rgba(16, 185, 129, 0.04);
  }
}

.no-scrollbar::-webkit-scrollbar { display: none; }
.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

.custom-scrollbar::-webkit-scrollbar { width: 4px; }
.custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
.custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(148,163,184,0.15); border-radius: 4px; }
