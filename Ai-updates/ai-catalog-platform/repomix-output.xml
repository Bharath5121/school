enum NotebookCategory {
  MODELS
  AGENTS
  APPS
  CLASS
  @@schema("content")
}

enum SourceType {
  URL
  PDF
  TEXT
  VIDEO
  YOUTUBE
  @@schema("content")
}

model MasterNotebook {
  id               String           @id @default(uuid())
  industrySlug     String
  category         NotebookCategory
  title            String
  description      String?          @db.Text
  workspaceSlug    String?          @map("workspace_slug")
