const mockGetModelsByIndustry = jest.fn();
const mockGetAgentsByIndustry = jest.fn();
const mockGetAppsByIndustry = jest.fn();

jest.mock('../repositories/models.repository', () => ({
  ModelsRepository: jest.fn().mockImplementation(() => ({
