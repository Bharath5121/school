import { BasicsRepository } from '../repositories/basics.repository';
import { AppError } from '../../../../shared/errors/AppError';

export interface CreateTopicDto {
  title: string;
  slug: string;
  tagline?: string;
  description?: string;
  icon?: string;
  color?: string;
  sortOrder?: number;
  concepts?: string[];
  keyTakeaways?: string[];
  isPublished?: boolean;
  videos?: CreateVideoDto[];
  articles?: CreateArticleDto[];
}

export interface UpdateTopicDto extends Partial<Omit<CreateTopicDto, 'videos' | 'articles'>> {}

export interface CreateVideoDto {
  title: string;
  url: string;
  channel?: string;
  duration?: string;
  sortOrder?: number;
  topicId: string;
}

export interface UpdateVideoDto extends Partial<CreateVideoDto> {}

export interface CreateArticleDto {
  title: string;
  url: string;
  source?: string;
  sortOrder?: number;
  topicId: string;
}

export interface UpdateArticleDto extends Partial<CreateArticleDto> {}

export class BasicsService {
  private repository = new BasicsRepository();

  async getAllTopics() {
    return this.repository.getAllTopics();
  }

  async getTopicBySlug(slug: string) {
    const topic = await this.repository.getTopicBySlug(slug);
    if (!topic) throw new AppError('Topic not found', 404);
    return topic;
  }

  async getTopicById(id: string) {
    const topic = await this.repository.getTopicById(id);
    if (!topic) throw new AppError('Topic not found', 404);
    return topic;
  }

  async createTopic(data: CreateTopicDto) {
    return this.repository.createTopic(data);
  }

  async updateTopic(id: string, data: UpdateTopicDto) {
    await this.getTopicById(id);
    return this.repository.updateTopic(id, data);
  }

  async deleteTopic(id: string) {
    await this.getTopicById(id);
    return this.repository.deleteTopic(id);
  }

  async createVideo(data: CreateVideoDto) {
    return this.repository.createVideo(data);
  }

  async updateVideo(id: string, data: UpdateVideoDto) {
    return this.repository.updateVideo(id, data);
  }

  async deleteVideo(id: string) {
    return this.repository.deleteVideo(id);
  }

  async createArticle(data: CreateArticleDto) {
    return this.repository.createArticle(data);
  }

  async updateArticle(id: string, data: UpdateArticleDto) {
    return this.repository.updateArticle(id, data);
  }

  async deleteArticle(id: string) {
    return this.repository.deleteArticle(id);
  }
}
