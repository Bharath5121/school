      mockList.mockResolvedValue(bookmarks);

      const result = await service.list('u1');

      expect(mockList).toHaveBeenCalledWith('u1', undefined);
      expect(result).toEqual(bookmarks);
    });

    it('filters bookmarks by contentType', async () => {
      mockList.mockResolvedValue([{ id: 'b1', contentType: 'model' }]);

      const result = await service.list('u1', 'model');

      expect(mockList).toHaveBeenCalledWith('u1', 'model');
      expect(result).toHaveLength(1);
    });

    it('returns empty array when user has no bookmarks', async () => {
