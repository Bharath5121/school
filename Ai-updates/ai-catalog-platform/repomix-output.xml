      expect(mockAdd).toHaveBeenCalledWith('u1', data);
      expect(result.title).toBe('GPT-5 Updated');
    });

    it('passes optional url and metadata', async () => {
      const data = {
        contentType: 'app',
        contentId: 'c2',
        title: 'MedApp',
        url: 'https://example.com',
        metadata: { tags: ['health'] },
      };
      mockAdd.mockResolvedValue({ id: 'b2', userId: 'u1', ...data });

      await service.add('u1', data);

      expect(mockAdd).toHaveBeenCalledWith('u1', data);
    });
