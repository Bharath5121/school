      mockRepo.getNotesForParent.mockResolvedValue({ notes: [], total: 0 });

      await service.getNotifications('parent-1', 3, 10);

      expect(mockRepo.getNotesForParent).toHaveBeenCalledWith('parent-1', 3, 10);
    });
  });

  describe('getUnreadCount', () => {
    it('returns the unread notification count wrapped in an object', async () => {
      mockRepo.getUnreadCount.mockResolvedValue(7);

      const result = await service.getUnreadCount('parent-1');

      expect(result).toEqual({ unreadCount: 7 });
      expect(mockRepo.getUnreadCount).toHaveBeenCalledWith('parent-1');
    });

    it('returns zero when all notifications are read', async () => {
      mockRepo.getUnreadCount.mockResolvedValue(0);

      const result = await service.getUnreadCount('parent-1');

      expect(result).toEqual({ unreadCount: 0 });
    });
  });

  describe('markAsRead', () => {
    it('marks a notification as read for the parent', async () => {
      mockRepo.markAsRead.mockResolvedValue({ count: 1 });

      await service.markAsRead('note-1', 'parent-1');

      expect(mockRepo.markAsRead).toHaveBeenCalledWith('note-1', 'parent-1');
    });

    it('completes without error even if note does not exist', async () => {
      mockRepo.markAsRead.mockResolvedValue({ count: 0 });

      await expect(service.markAsRead('nonexistent', 'parent-1')).resolves.toBeUndefined();
      expect(mockRepo.markAsRead).toHaveBeenCalledWith('nonexistent', 'parent-1');
    });

    it('propagates repository errors', async () => {
      mockRepo.markAsRead.mockRejectedValue(new Error('DB connection lost'));

      await expect(service.markAsRead('note-1', 'parent-1')).rejects.toThrow('DB connection lost');
    });
  });
});
