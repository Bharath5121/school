const mockCreate = jest.fn();

jest.mock('@anthropic-ai/sdk', () => {
  return jest.fn().mockImplementation(() => ({
    messages: { create: mockCreate },
  }));
});

jest.mock('../../../../config/env', () => ({
  env: { CLAUDE_API_KEY: 'test-key' },
}));

jest.mock('../../../../shared/logger/logger', () => ({
  __esModule: true,
  default: { error: jest.fn(), info: jest.fn() },
}));

import { AskAIService } from '../services/askAI.service';

describe('AskAIService', () => {
  let service: AskAIService;
  let mockRes: { write: jest.Mock; end: jest.Mock };

  beforeEach(() => {
    jest.clearAllMocks();
    service = new AskAIService();
    mockRes = { write: jest.fn(), end: jest.fn() };
  });

  describe('streamResponse', () => {
    it('streams Claude API response chunks to the client', async () => {
      const chunks = [
        { type: 'content_block_delta', delta: { type: 'text_delta', text: 'Hello' } },
        { type: 'content_block_delta', delta: { type: 'text_delta', text: ' world' } },
      ];

      mockCreate.mockResolvedValue({
        [Symbol.asyncIterator]: async function* () {
          for (const chunk of chunks) yield chunk;
        },
      });

      await service.streamResponse('What is AI?', 'healthcare', mockRes as any);

      expect(mockCreate).toHaveBeenCalledWith(
        expect.objectContaining({
          model: 'claude-3-haiku-20240307',
          max_tokens: 1024,
          stream: true,
          messages: [{ role: 'user', content: 'What is AI?' }],
        }),
      );
      expect(mockRes.write).toHaveBeenCalledTimes(2);
      expect(mockRes.write).toHaveBeenCalledWith(`data: ${JSON.stringify({ text: 'Hello' })}\n\n`);
      expect(mockRes.write).toHaveBeenCalledWith(`data: ${JSON.stringify({ text: ' world' })}\n\n`);
      expect(mockRes.end).toHaveBeenCalled();
    });

    it('includes the fieldSlug in the system prompt', async () => {
      mockCreate.mockResolvedValue({
        [Symbol.asyncIterator]: async function* () {},
      });

      await service.streamResponse('Tell me more', 'finance', mockRes as any);

      const callArgs = mockCreate.mock.calls[0][0];
      expect(callArgs.system).toContain('finance');
    });

    it('skips non-text-delta events from the stream', async () => {
      const chunks = [
        { type: 'message_start', message: {} },
        { type: 'content_block_delta', delta: { type: 'text_delta', text: 'data' } },
        { type: 'message_stop' },
      ];

      mockCreate.mockResolvedValue({
        [Symbol.asyncIterator]: async function* () {
          for (const chunk of chunks) yield chunk;
        },
      });

      await service.streamResponse('Question', 'tech', mockRes as any);

      expect(mockRes.write).toHaveBeenCalledTimes(1);
      expect(mockRes.write).toHaveBeenCalledWith(`data: ${JSON.stringify({ text: 'data' })}\n\n`);
      expect(mockRes.end).toHaveBeenCalled();
    });

    it('writes an error event and ends response when Claude API throws', async () => {
      mockCreate.mockRejectedValue(new Error('API timeout'));

      await service.streamResponse('Question', 'healthcare', mockRes as any);

      expect(mockRes.write).toHaveBeenCalledWith(
        `data: ${JSON.stringify({ error: 'Failed to generate response' })}\n\n`,
      );
      expect(mockRes.end).toHaveBeenCalled();
    });
  });
});

describe('AskAIService (no API key)', () => {
  let service: AskAIService;
  let mockRes: { write: jest.Mock; end: jest.Mock };

  beforeEach(() => {
    jest.clearAllMocks();
    jest.resetModules();
    mockRes = { write: jest.fn(), end: jest.fn() };
  });

  it('sends a mock response when CLAUDE_API_KEY is not configured', async () => {
    jest.doMock('../../../../config/env', () => ({
      env: { CLAUDE_API_KEY: '' },
    }));
    jest.doMock('@anthropic-ai/sdk', () => jest.fn().mockImplementation(() => ({})));

    const { AskAIService: Fresh } = await import('../services/askAI.service');
    service = new Fresh();

    await service.streamResponse('What is ML?', 'data-science', mockRes as any);

    expect(mockRes.write).toHaveBeenCalledTimes(1);
    const written = mockRes.write.mock.calls[0][0];
    expect(written).toContain('What is ML?');
    expect(written).toContain('data-science');
    expect(mockRes.end).toHaveBeenCalled();
  });
});
