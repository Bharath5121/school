generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "users", "catalog", "user_activity", "content", "user_network"]
}

// ═══════════════════════════════════════════════════════════════════════
// AUTH SCHEMA
// ═══════════════════════════════════════════════════════════════════════

enum UserRole {
  STUDENT
  PARENT
  TEACHER
  ADMIN

  @@schema("auth")
}

enum TokenType {
  RESET_PASSWORD
  VERIFY_EMAIL

  @@schema("auth")
}

model User {
  id                  String         @id @default(uuid())
  email               String         @unique
  name                String         @map("full_name")
  role                UserRole       @default(STUDENT)
  emailVerified       DateTime?      @map("email_verified_at")
  failedLoginAttempts Int            @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?      @map("locked_until")
  deletedAt           DateTime?      @map("deleted_at")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  secret        UserSecret?
  profile       Profile?
  sessions      Session[]
  refreshTokens RefreshToken[]
  authTokens    AuthToken[]
  parentLinks   ParentChildLink[] @relation("ParentLinks")
  childLinks    ParentChildLink[] @relation("ChildLinks")
  classChats        ClassChat[]
  notebookMessages  NotebookChatMessage[]

  @@map("users")
  @@schema("auth")
}

model Session {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")
  isRevoked Boolean   @default(false) @map("is_revoked")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
  @@schema("auth")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
  @@schema("auth")
}

model AuthToken {
  id        String    @id @default(uuid())
  token     String    @unique
  type      TokenType
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_tokens")
  @@schema("auth")
}

model AccessTokenBlacklist {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("access_token_blacklist")
  @@schema("auth")
}

model UserSecret {
  userId             String   @id @map("user_id")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash       String?  @map("password_hash")
  twoFactorSecret    String?  @map("two_factor_secret")
  recoveryCodes      Json     @default("[]") @map("recovery_codes")
  lastPasswordChange DateTime @default(now()) @map("last_password_change")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("user_secrets")
  @@schema("auth")
}

// ═══════════════════════════════════════════════════════════════════════
// USERS SCHEMA
// ═══════════════════════════════════════════════════════════════════════

model Profile {
  userId              String    @id @map("user_id")
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarUrl           String?   @map("avatar_url")
  bio                 String?
  gradeLevel          String?   @map("grade_level")
  stream              String?
  parentEmail         String?   @map("parent_email")
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")
  learningStyle       Json?     @map("learning_style")
  preferences         Json      @default("{\"theme\": \"emerald\", \"notifications\": {\"email\": true, \"push\": false}}")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  interests Interest[]

  @@map("profiles")
  @@schema("users")
}

model Interest {
  id            BigInt   @id @default(autoincrement())
  userId        String   @map("user_id")
  fieldName     String   @map("field_name")
  interestLevel Int      @default(5) @map("interest_level")
  profile       Profile  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([userId, fieldName])
  @@map("user_interests")
  @@schema("users")
}

// ═══════════════════════════════════════════════════════════════════════
// CATALOG SCHEMA
// ═══════════════════════════════════════════════════════════════════════

enum FeedContentType {
  MODEL
  ADVANCEMENT
  AGENT
  PRODUCT
  LEARNING
  CAREER
  GUIDE

  @@schema("catalog")
}

model FeedItem {
  id                String          @id @default(uuid())
  title             String
  content           String?         @db.Text
  contentType       FeedContentType @map("content_type")
  targetRole        UserRole        @default(STUDENT) @map("target_role")
  fieldSlug         String          @map("field_slug")
  summary           String?         @db.Text @map("summary")
  careerImpactScore Int?            @map("career_impact_score")
  careerImpactText  String?         @db.Text @map("career_impact_text")
  views             Int             @default(0)
  metadata          Json            @default("{}")
  publishedAt       DateTime        @default(now()) @map("published_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  bookmarks      Bookmark[]
  readingHistory ReadingHistory[]

  @@map("feed_items")
  @@schema("catalog")
}

// ═══════════════════════════════════════════════════════════════════════
// USER_ACTIVITY SCHEMA
// ═══════════════════════════════════════════════════════════════════════

enum SkillStatus {
  NOT_STARTED
  EXPLORING
  LEARNED

  @@schema("user_activity")
}

model Bookmark {
  userId     String   @map("user_id")
  feedItemId String   @map("feed_item_id")
  createdAt  DateTime @default(now()) @map("created_at")

  feedItem FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)

  @@id([userId, feedItemId])
  @@index([userId])
  @@map("bookmarks")
  @@schema("user_activity")
}

model ReadingHistory {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  feedItemId       String   @map("feed_item_id")
  timeSpentSeconds Int      @default(0) @map("time_spent_seconds")
  completed        Boolean  @default(false)
  lastReadAt       DateTime @default(now()) @map("last_read_at")
  createdAt        DateTime @default(now()) @map("created_at")

  feedItem FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)

  @@unique([userId, feedItemId])
  @@index([userId])
  @@index([lastReadAt])
  @@map("reading_history")
  @@schema("user_activity")
}

model UserSkillProgress {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  skillId   String      @map("skill_id")
  status    SkillStatus @default(NOT_STARTED)
  updatedAt DateTime    @updatedAt @map("updated_at")
  createdAt DateTime    @default(now()) @map("created_at")

  @@unique([userId, skillId])
  @@map("skill_progress")
  @@schema("user_activity")
}

model UserCareerExplored {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  careerJobId String   @map("career_job_id")
  exploredAt  DateTime @default(now()) @map("explored_at")

  @@unique([userId, careerJobId])
  @@map("career_explored")
  @@schema("user_activity")
}

model ContentBookmark {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  contentType String   @map("content_type")
  contentId   String   @map("content_id")
  title       String
  url         String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([userId, contentType, contentId])
  @@index([userId])
  @@map("content_bookmarks")
  @@schema("user_activity")
}

// ═══════════════════════════════════════════════════════════════════════
// CONTENT SCHEMA (formerly home-service public schema)
// ═══════════════════════════════════════════════════════════════════════

enum CareerImpactLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@schema("content")
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED

  @@schema("content")
}

enum JobDemand {
  GROWING
  STABLE
  AT_RISK

  @@schema("content")
}

enum JobTimeline {
  NOW
  YEAR_2030
  FUTURE

  @@schema("content")
}

model Industry {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String
  icon        String
  color       String
  gradient    String
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  models     AIModel[]
  agents     AIAgent[]
  apps       AIApp[]
  questions  PredefinedQuestion[]
  guides     Guide[]
  prompts    PromptTemplate[]
  careerPaths CareerPath[]
  skills     Skill[]
  notebooks  MasterNotebook[]

  @@schema("content")
}

model AIModel {
  id               String    @id @default(cuid())
  name             String
  description      String    @db.Text
  builtBy          String
  builtByRole      String    @default("") @map("built_by_role")
  industrySlug     String
  industry         Industry  @relation(fields: [industrySlug], references: [slug])
  difficultyLevel  String    @default("Beginner") @map("difficulty_level")
  gradeLevel       String[]  @default([]) @map("grade_level")
  modelType        String    @default("") @map("model_type")
  releaseYear      String    @default("") @map("release_year")
  parameters       String    @default("") @map("parameters")
  inputType        String[]  @default([]) @map("input_type")
  outputType       String[]  @default([]) @map("output_type")
  whatItDoes       String    @default("") @map("what_it_does") @db.Text
  whatItAutomates  String    @default("") @map("what_it_automates") @db.Text
  skillsNeeded     String[]  @default([]) @map("skills_needed")
  useCaseTags      String[]  @default([]) @map("use_case_tags")
  careerImpact     String    @db.Text
  whatToLearnFirst String    @default("") @map("what_to_learn_first") @db.Text
  realWorldExample String    @default("") @map("real_world_example") @db.Text
  isFree           Boolean   @default(false)
  tryUrl           String?
  notebookLmUrl    String?   @map("notebook_lm_url")
  youtubeUrl       String?   @map("youtube_url")
  udemyUrl         String?   @map("udemy_url")
  sourceUrl        String?   @map("source_url")
  huggingFaceUrl   String?   @map("hugging_face_url")
  releaseDate      DateTime?
  whatToLearn      String[]
  tags             String[]
  sortOrder        Int       @default(0) @map("sort_order")
  isPublished      Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@schema("content")
}

model AIAgent {
  id               String   @id @default(cuid())
  name             String
  description      String   @db.Text
  builtBy          String
  builtByRole      String   @default("") @map("built_by_role")
  industrySlug     String
  industry         Industry @relation(fields: [industrySlug], references: [slug])
  difficultyLevel  String   @default("Beginner") @map("difficulty_level")
  gradeLevel       String[] @default([]) @map("grade_level")
  agentType        String   @default("") @map("agent_type")
  whatItDoes       String   @db.Text
  whatItAutomates  String   @default("") @map("what_it_automates") @db.Text
  humanJobItHelps  String
  humanPartnership String   @default("") @map("human_partnership")
  skillsNeeded     String[]
  inputType        String[] @default([]) @map("input_type")
  outputType       String[] @default([]) @map("output_type")
  useCaseTags      String[] @default([]) @map("use_case_tags")
  careerImpact     String   @db.Text
  whatToLearnFirst String   @default("") @map("what_to_learn_first") @db.Text
  realWorldExample String   @default("") @map("real_world_example") @db.Text
  isFree           Boolean  @default(false)
  tryUrl           String?
  notebookLmUrl    String?  @map("notebook_lm_url")
  youtubeUrl       String?  @map("youtube_url")
  udemyUrl         String?  @map("udemy_url")
  sourceUrl        String?  @map("source_url")
  huggingFaceUrl   String?  @map("hugging_face_url")
  sortOrder        Int      @default(0) @map("sort_order")
  isPublished      Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@schema("content")
}


model AIApp {
  id           String   @id @default(cuid())
  name         String
  description  String   @db.Text
  builtBy      String
  builtByRole  String
  industrySlug String
  industry     Industry @relation(fields: [industrySlug], references: [slug])
  whoUsesIt    String
  tryUrl       String?
  isFree       Boolean  @default(false)
  careerImpact String   @db.Text
  sortOrder    Int      @default(0) @map("sort_order")
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@schema("content")
}

model PredefinedQuestion {
  id           String   @id @default(cuid())
  question     String
  industrySlug String
  industry     Industry @relation(fields: [industrySlug], references: [slug])
  category     String
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@schema("content")
}

model BasicsTopic {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  tagline      String
  description  String   @db.Text
  icon         String
  color        String
  sortOrder    Int      @default(0)
  concepts     String[]
  keyTakeaways String[]
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  videos   BasicsVideo[]
  articles BasicsArticle[]

  @@schema("content")
}

model BasicsVideo {
  id        String      @id @default(cuid())
  title     String
  url       String
  channel   String
  duration  String
  sortOrder Int         @default(0)
  topicId   String
  topic     BasicsTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@schema("content")
}

model BasicsArticle {
  id        String      @id @default(cuid())
  title     String
  url       String
  source    String
  sortOrder Int         @default(0)
  topicId   String
  topic     BasicsTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@schema("content")
}

model Guide {
  id           String          @id @default(cuid())
  title        String
  description  String          @db.Text
  difficulty   DifficultyLevel @default(BEGINNER)
  timeRequired String
  toolsNeeded  String[]
  industrySlug String
  industry     Industry        @relation(fields: [industrySlug], references: [slug])
  whatYouLearn String          @db.Text
  steps        Json            @default("[]")
  sortOrder    Int             @default(0) @map("sort_order")
  isPublished  Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@schema("content")
}

model PromptTemplate {
  id           String   @id @default(cuid())
  title        String
  prompt       String   @db.Text
  useCase      String
  industrySlug String
  industry     Industry @relation(fields: [industrySlug], references: [slug])
  category     String
  sortOrder    Int      @default(0)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@schema("content")
}

model CareerPath {
  id              String   @id @default(cuid())
  industrySlug    String
  industry        Industry @relation(fields: [industrySlug], references: [slug])
  title           String
  description     String   @db.Text
  aiImpactSummary String   @db.Text
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  jobs CareerJob[]

  @@schema("content")
}

model CareerJob {
  id             String     @id @default(cuid())
  careerPathId   String
  careerPath     CareerPath @relation(fields: [careerPathId], references: [id], onDelete: Cascade)
  title          String
  salaryRangeMin Int
  salaryRangeMax Int
  currency       String     @default("USD")
  demand         JobDemand  @default(GROWING)
  requiredDegree String
  requiredSkills String[]
  futureSkills   String[]
  howAiChanges   String     @db.Text
  timeline       JobTimeline @default(NOW)
  googleUrl      String?     @map("google_url")
  notebookLmUrl  String?     @map("notebook_lm_url")
  sortOrder      Int        @default(0)
  createdAt      DateTime   @default(now())

  @@schema("content")
}

model Skill {
  id            String          @id @default(cuid())
  name          String
  description   String          @db.Text
  industrySlug  String
  industry      Industry        @relation(fields: [industrySlug], references: [slug])
  level         DifficultyLevel @default(BEGINNER)
  whyItMatters  String          @db.Text
  learnUrl      String?
  notebookLmUrl String?         @map("notebook_lm_url")
  timeToLearn   String
  category      String
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())

  @@schema("content")
}

// ═══════════════════════════════════════════════════════════════════════
// NOTEBOOKS (AnythingLLM Integration)
// ═══════════════════════════════════════════════════════════════════════

enum NotebookCategory {
  MODELS
  AGENTS
  APPS
  CLASS

  @@schema("content")
}

enum SourceType {
  URL
  PDF
  TEXT
  VIDEO
  YOUTUBE

  @@schema("content")
}

model MasterNotebook {
  id               String           @id @default(cuid())
  industrySlug     String
  category         NotebookCategory
  title            String
  description      String?          @db.Text
  workspaceSlug    String?          @map("workspace_slug")
  workspaceCreated Boolean          @default(false) @map("workspace_created")
  gradeLevel       String?          @map("grade_level")
  difficultyLevel  String?          @map("difficulty_level")
  sourcesCount     Int              @default(0) @map("sources_count")
  published        Boolean          @default(false)
  createdBy        String           @map("created_by")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  industry     Industry              @relation(fields: [industrySlug], references: [slug])
  sources      NotebookSource[]
  accessLogs   NotebookAccessLog[]
  chatMessages NotebookChatMessage[]

  @@index([published])
  @@index([gradeLevel])
  @@map("master_notebooks")
  @@schema("content")
}

model NotebookSource {
  id         String         @id @default(cuid())
  notebookId String         @map("notebook_id")
  type       SourceType
  title      String
  url        String?
  filePath   String?        @map("file_path")
  metadata   Json?
  sortOrder  Int            @default(0) @map("sort_order")
  createdAt  DateTime       @default(now()) @map("created_at")

  notebook MasterNotebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@index([notebookId])
  @@map("notebook_sources")
  @@schema("content")
}

model NotebookAccessLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  notebookId String   @map("notebook_id")
  accessedAt DateTime @default(now()) @map("accessed_at")

  notebook MasterNotebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@index([userId, notebookId])
  @@index([userId, accessedAt])
  @@map("notebook_access_logs")
  @@schema("user_activity")
}

model NotebookChatMessage {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  notebookId    String   @map("notebook_id")
  workspaceSlug String   @map("workspace_slug")
  message       String   @db.Text
  response      String   @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  notebook MasterNotebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@index([userId, notebookId])
  @@index([notebookId, createdAt])
  @@map("notebook_chat_messages")
  @@schema("user_activity")
}

// ═══════════════════════════════════════════════════════════════════════
// USER_NETWORK SCHEMA (Parent-Child & Teacher-Parent)
// ═══════════════════════════════════════════════════════════════════════

model ParentChildLink {
  parentId  String   @map("parent_id")
  childId   String   @map("child_id")
  createdAt DateTime @default(now()) @map("created_at")

  parent User @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  child  User @relation("ChildLinks", fields: [childId], references: [id], onDelete: Cascade)

  @@id([parentId, childId])
  @@map("parent_child_links")
  @@schema("user_network")
}

model TeacherNote {
  id        String   @id @default(uuid())
  teacherId String   @map("teacher_id")
  studentId String   @map("student_id")
  parentId  String?  @map("parent_id")
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([parentId])
  @@index([studentId])
  @@map("teacher_notes")
  @@schema("user_network")
}

// ═══════════════════════════════════════════════════════════════════════
// CLASS CHAT (Real-Time Student Messaging)
// ═══════════════════════════════════════════════════════════════════════

model ClassChat {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   String   @default("general")
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([channel, createdAt])
  @@map("class_chats")
  @@schema("user_activity")
}
