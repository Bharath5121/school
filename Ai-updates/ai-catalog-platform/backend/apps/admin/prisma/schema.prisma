generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["app_auth", "users", "catalog", "user_activity", "content", "user_network"]
}

// ═══════════════════════════════════════════════════════════════════════
// AUTH SCHEMA — Supabase Auth handles login/sessions/tokens.
// We keep a lightweight User record synced via DB trigger.
// ═══════════════════════════════════════════════════════════════════════

enum UserRole {
  STUDENT
  PARENT
  TEACHER
  ADMIN

  @@schema("app_auth")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String    @map("full_name")
  role          UserRole  @default(STUDENT)
  emailVerified DateTime? @map("email_verified_at")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  profile            Profile?
  parentLinks        ParentChildLink[]       @relation("ParentLinks")
  childLinks         ParentChildLink[]       @relation("ChildLinks")
  classChats         ClassChat[]
  notebookMessages   NotebookChatMessage[]
  bookmarks          Bookmark[]
  readingHistory     ReadingHistory[]
  skillProgress      UserSkillProgress[]
  careersExplored    UserCareerExplored[]
  contentBookmarks   ContentBookmark[]
  contentViewHistory ContentViewHistory[]
  notebookAccessLogs NotebookAccessLog[]
  teacherNotesSent   TeacherNote[]           @relation("TeacherNotes")
  teacherNotesAbout  TeacherNote[]           @relation("StudentNotes")
  teacherNotesFor    TeacherNote[]           @relation("ParentNotes")
  discoveryChatMsgs      DiscoveryChatMsg[]
  basicsTopicChatMsgs    BasicsTopicChatMsg[]
  labItemChatMsgs        LabItemChatMsg[]
  buddyConversations     BuddyConversation[]
  onboardingCompleted    Boolean  @default(false) @map("onboarding_completed")
  selectedIndustries     UserIndustrySelection[]

  @@map("users")
  @@schema("app_auth")
}

model UserIndustrySelection {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  industrySlug String   @map("industry_slug")
  createdAt    DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  industry Industry @relation(fields: [industrySlug], references: [slug], onDelete: Cascade)

  @@unique([userId, industrySlug])
  @@index([userId])
  @@map("user_industry_selections")
  @@schema("app_auth")
}

// ═══════════════════════════════════════════════════════════════════════
// USERS SCHEMA
// ═══════════════════════════════════════════════════════════════════════

model Profile {
  userId              String   @id @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarUrl           String?  @map("avatar_url")
  bio                 String?
  gradeLevel          String?  @map("grade_level")
  stream              String?
  parentEmail         String?  @map("parent_email")
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  learningStyle       Json?    @map("learning_style")
  preferences         Json     @default("{\"theme\": \"emerald\", \"notifications\": {\"email\": true, \"push\": false}}")
  updatedAt           DateTime @updatedAt @map("updated_at")

  interests Interest[]

  @@map("profiles")
  @@schema("users")
}

model Interest {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  fieldName     String   @map("field_name")
  interestLevel Int      @default(5) @map("interest_level")
  profile       Profile  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([userId, fieldName])
  @@map("user_interests")
  @@schema("users")
}

// ═══════════════════════════════════════════════════════════════════════
// CATALOG SCHEMA
// ═══════════════════════════════════════════════════════════════════════

enum FeedContentType {
  MODEL
  ADVANCEMENT
  AGENT
  PRODUCT
  LEARNING
  CAREER
  GUIDE

  @@schema("catalog")
}

model FeedItem {
  id                String          @id @default(uuid())
  title             String
  content           String?         @db.Text
  contentType       FeedContentType @map("content_type")
  targetRole        UserRole        @default(STUDENT) @map("target_role")
  fieldSlug         String          @map("field_slug")
  summary           String?         @db.Text @map("summary")
  careerImpactScore Int?            @map("career_impact_score")
  careerImpactText  String?         @db.Text @map("career_impact_text")
  views             Int             @default(0)
  metadata          Json            @default("{}")
  publishedAt       DateTime        @default(now()) @map("published_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  bookmarks      Bookmark[]
  readingHistory ReadingHistory[]

  @@index([fieldSlug])
  @@map("feed_items")
  @@schema("catalog")
}

// ═══════════════════════════════════════════════════════════════════════
// DISCOVERIES
// ═══════════════════════════════════════════════════════════════════════

enum DiscoveryLinkType {
  MODEL
  AGENT
  APP

  @@schema("catalog")
}

model Discovery {
  id                      String           @id @default(uuid())
  title                   String
  slug                    String           @unique
  summary                 String           @db.Text
  description             String           @db.Text
  coverImageUrl           String?          @map("cover_image_url")
  industrySlug            String           @map("industry_slug")
  industry                Industry         @relation(fields: [industrySlug], references: [slug])
  difficulty              DifficultyLevel  @default(BEGINNER)
  videoUrl                String?          @map("video_url")
  videoTitle              String?          @map("video_title")
  notebookLmUrl           String?          @map("notebook_lm_url")
  notebookDescription     String?          @db.Text @map("notebook_description")
  architectureDescription String?          @db.Text @map("architecture_description")
  architectureDiagramUrl  String?          @map("architecture_diagram_url")
  isPublished             Boolean          @default(false) @map("is_published")
  publishedAt             DateTime?        @map("published_at")
  isFeatured              Boolean          @default(false) @map("is_featured")
  sortOrder               Int              @default(0) @map("sort_order")
  xp                      Int              @default(0)
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @updatedAt @map("updated_at")

  links        DiscoveryLink[]
  chatMessages DiscoveryChatMsg[]

  @@index([industrySlug])
  @@index([isPublished, publishedAt])
  @@index([isFeatured])
  @@map("discoveries")
  @@schema("catalog")
}

model DiscoveryLink {
  id          String            @id @default(uuid())
  discoveryId String            @map("discovery_id")
  discovery   Discovery         @relation(fields: [discoveryId], references: [id], onDelete: Cascade)
  type        DiscoveryLinkType
  name        String
  description String?
  redirectUrl String?           @map("redirect_url")
  sortOrder   Int               @default(0) @map("sort_order")
  createdAt   DateTime          @default(now()) @map("created_at")

  @@index([discoveryId])
  @@map("discovery_links")
  @@schema("catalog")
}

model DiscoveryChatMsg {
  id          String   @id @default(uuid())
  discoveryId String   @map("discovery_id")
  discovery   Discovery @relation(fields: [discoveryId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message     String   @db.Text
  response    String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([discoveryId, createdAt])
  @@index([userId])
  @@map("discovery_chat_messages")
  @@schema("catalog")
}

// ═══════════════════════════════════════════════════════════════════════
// USER_ACTIVITY SCHEMA
// ═══════════════════════════════════════════════════════════════════════

enum SkillStatus {
  NOT_STARTED
  EXPLORING
  LEARNED

  @@schema("user_activity")
}

model Bookmark {
  userId     String   @map("user_id")
  feedItemId String   @map("feed_item_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedItem FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)

  @@id([userId, feedItemId])
  @@index([userId])
  @@index([feedItemId])
  @@map("bookmarks")
  @@schema("user_activity")
}

model ReadingHistory {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  feedItemId       String   @map("feed_item_id")
  timeSpentSeconds Int      @default(0) @map("time_spent_seconds")
  completed        Boolean  @default(false)
  lastReadAt       DateTime @default(now()) @map("last_read_at")
  createdAt        DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedItem FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)

  @@unique([userId, feedItemId])
  @@index([userId])
  @@index([lastReadAt])
  @@map("reading_history")
  @@schema("user_activity")
}

model UserSkillProgress {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  skillId   String      @map("skill_id")
  status    SkillStatus @default(NOT_STARTED)
  updatedAt DateTime    @updatedAt @map("updated_at")
  createdAt DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@index([userId])
  @@map("skill_progress")
  @@schema("user_activity")
}

model UserCareerExplored {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  careerJobId String   @map("career_job_id")
  exploredAt  DateTime @default(now()) @map("explored_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, careerJobId])
  @@index([userId])
  @@map("career_explored")
  @@schema("user_activity")
}

model ContentBookmark {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  contentType String   @map("content_type")
  contentId   String   @map("content_id")
  title       String
  url         String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentType, contentId])
  @@index([userId])
  @@map("content_bookmarks")
  @@schema("user_activity")
}

model ContentViewHistory {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  contentType String   @map("content_type")
  contentId   String   @map("content_id")
  title       String
  slug        String?
  icon        String?
  metadata    Json     @default("{}")
  viewedAt    DateTime @default(now()) @map("viewed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, viewedAt(sort: Desc)])
  @@index([userId, contentType, contentId])
  @@map("content_view_history")
  @@schema("user_activity")
}

// ═══════════════════════════════════════════════════════════════════════
// CONTENT SCHEMA
// ═══════════════════════════════════════════════════════════════════════

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED

  @@schema("content")
}

enum JobDemand {
  GROWING
  STABLE
  AT_RISK

  @@schema("content")
}

enum JobTimeline {
  NOW
  YEAR_2030
  FUTURE

  @@schema("content")
}

model Industry {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String
  icon        String
  color       String
  gradient    String
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  models      AIModel[]
  agents      AIAgent[]
  apps        AIApp[]
  questions   PredefinedQuestion[]
  guides      Guide[]
  prompts     PromptTemplate[]
  careerPaths CareerPath[]
  skills      Skill[]
  notebooks   MasterNotebook[]
  discoveries          Discovery[]
  trendingApps         TrendingApp[]
  userSelections       UserIndustrySelection[]

  @@schema("content")
}

model AIModel {
  id               String          @id @default(uuid())
  name             String
  description      String          @db.Text
  builtBy          String
  builtByRole      String          @default("") @map("built_by_role")
  industrySlug     String
  industry         Industry        @relation(fields: [industrySlug], references: [slug])
  difficultyLevel  DifficultyLevel @default(BEGINNER) @map("difficulty_level")
  gradeLevel       String[]        @default([]) @map("grade_level")
  modelType        String          @default("") @map("model_type")
  releaseYear      String          @default("") @map("release_year")
  parameters       String          @default("") @map("parameters")
  inputType        String[]        @default([]) @map("input_type")
  outputType       String[]        @default([]) @map("output_type")
  whatItDoes       String          @default("") @map("what_it_does") @db.Text
  whatItAutomates  String          @default("") @map("what_it_automates") @db.Text
  skillsNeeded     String[]        @default([]) @map("skills_needed")
  useCaseTags      String[]        @default([]) @map("use_case_tags")
  careerImpact     String          @db.Text
  whatToLearnFirst String          @default("") @map("what_to_learn_first") @db.Text
  realWorldExample String          @default("") @map("real_world_example") @db.Text
  isFree           Boolean         @default(false)
  tryUrl           String?
  notebookLmUrl    String?         @map("notebook_lm_url")
  youtubeUrl       String?         @map("youtube_url")
  udemyUrl         String?         @map("udemy_url")
  sourceUrl        String?         @map("source_url")
  huggingFaceUrl   String?         @map("hugging_face_url")
  releaseDate      DateTime?
  whatToLearn      String[]
  tags             String[]
  sortOrder        Int             @default(0) @map("sort_order")
  isPublished      Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([industrySlug])
  @@schema("content")
}

model AIAgent {
  id               String          @id @default(uuid())
  name             String
  description      String          @db.Text
  builtBy          String
  builtByRole      String          @default("") @map("built_by_role")
  industrySlug     String
  industry         Industry        @relation(fields: [industrySlug], references: [slug])
  difficultyLevel  DifficultyLevel @default(BEGINNER) @map("difficulty_level")
  gradeLevel       String[]        @default([]) @map("grade_level")
  agentType        String          @default("") @map("agent_type")
  whatItDoes       String          @db.Text
  whatItAutomates  String          @default("") @map("what_it_automates") @db.Text
  humanJobItHelps  String
  humanPartnership String          @default("") @map("human_partnership")
  skillsNeeded     String[]
  inputType        String[]        @default([]) @map("input_type")
  outputType       String[]        @default([]) @map("output_type")
  useCaseTags      String[]        @default([]) @map("use_case_tags")
  careerImpact     String          @db.Text
  whatToLearnFirst String          @default("") @map("what_to_learn_first") @db.Text
  realWorldExample String          @default("") @map("real_world_example") @db.Text
  isFree           Boolean         @default(false)
  tryUrl           String?
  notebookLmUrl    String?         @map("notebook_lm_url")
  youtubeUrl       String?         @map("youtube_url")
  udemyUrl         String?         @map("udemy_url")
  sourceUrl        String?         @map("source_url")
  huggingFaceUrl   String?         @map("hugging_face_url")
  sortOrder        Int             @default(0) @map("sort_order")
  isPublished      Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([industrySlug])
  @@schema("content")
}

model AIApp {
  id           String   @id @default(uuid())
  name         String
  description  String   @db.Text
  builtBy      String
  builtByRole  String
  industrySlug String
  industry     Industry @relation(fields: [industrySlug], references: [slug])
  whoUsesIt    String
  tryUrl       String?
  isFree       Boolean  @default(false)
  careerImpact String   @db.Text
  sortOrder    Int      @default(0) @map("sort_order")
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([industrySlug])
  @@schema("content")
}

model PredefinedQuestion {
  id           String   @id @default(uuid())
  question     String
  industrySlug String
  industry     Industry @relation(fields: [industrySlug], references: [slug])
  category     String
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([industrySlug])
  @@schema("content")
}

model BasicsChapter {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String?  @db.Text
  icon        String?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topics BasicsTopic[]

  @@schema("content")
}

enum BasicsLinkType {
  MODEL
  AGENT
  APP

  @@schema("content")
}

model BasicsTopic {
  id                      String   @id @default(uuid())
  slug                    String   @unique
  title                   String
  tagline                 String
  description             String   @db.Text
  icon                    String
  color                   String
  sortOrder               Int      @default(0)
  concepts                String[]
  keyTakeaways            String[]
  difficulty              String   @default("beginner")
  xp                      Int      @default(40)
  videoUrl                String?
  videoTitle              String?
  notebookLmUrl           String?
  notebookDescription     String?  @db.Text
  architectureDescription String?  @db.Text
  architectureDiagramUrl  String?
  isPublished             Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  chapterId String?
  chapter   BasicsChapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  videos       BasicsVideo[]
  articles     BasicsArticle[]
  links        BasicsTopicLink[]
  chatMessages BasicsTopicChatMsg[]

  @@index([chapterId])
  @@schema("content")
}

model BasicsVideo {
  id        String      @id @default(uuid())
  title     String
  url       String
  channel   String
  duration  String
  sortOrder Int         @default(0)
  topicId   String
  topic     BasicsTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([topicId])
  @@schema("content")
}

model BasicsArticle {
  id        String      @id @default(uuid())
  title     String
  url       String
  source    String
  sortOrder Int         @default(0)
  topicId   String
  topic     BasicsTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([topicId])
  @@schema("content")
}

model BasicsTopicLink {
  id          String         @id @default(uuid())
  topicId     String
  topic       BasicsTopic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  type        BasicsLinkType
  name        String
  description String?
  redirectUrl String?
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())

  @@index([topicId])
  @@schema("content")
}

model BasicsTopicChatMsg {
  id        String      @id @default(uuid())
  topicId   String
  topic     BasicsTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String      @db.Text
  response  String?     @db.Text
  createdAt DateTime    @default(now())

  @@index([topicId, createdAt])
  @@index([userId])
  @@schema("content")
}

// ═══════════════════════════════════════════════════════════════════════
// AI LAB
// ═══════════════════════════════════════════════════════════════════════

enum LabItemType {
  MODEL
  APP

  @@schema("content")
}

model LabCategory {
  id          String    @id @default(uuid())
  slug        String    @unique
  title       String
  description String?   @db.Text
  icon        String?
  sortOrder   Int       @default(0)
  isPublished Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items LabItem[]

  @@schema("content")
}

model LabItem {
  id          String      @id @default(uuid())
  slug        String      @unique
  title       String
  tagline     String?
  description String?     @db.Text
  icon        String?
  provider    String?
  type        LabItemType
  useCases    String[]
  features    String[]
  sortOrder   Int         @default(0)
  isPublished Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  categoryId String
  category   LabCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  chatMessages LabItemChatMsg[]

  @@index([categoryId])
  @@index([type])
  @@schema("content")
}

model LabItemChatMsg {
  id        String   @id @default(uuid())
  itemId    String
  item      LabItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String   @db.Text
  response  String?  @db.Text
  createdAt DateTime @default(now())

  @@index([itemId, createdAt])
  @@index([userId])
  @@schema("content")
}

model TrendingCategory {
  id          String    @id @default(uuid())
  slug        String    @unique
  title       String
  description String?   @db.Text
  icon        String?
  sortOrder   Int       @default(0)
  isPublished Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  apps TrendingApp[]

  @@schema("content")
}

model TrendingApp {
  id           String    @id @default(uuid())
  slug         String    @unique
  name         String
  tagline      String?
  description  String?   @db.Text
  icon         String?
  logoUrl        String?
  coverImageUrl  String?
  provider       String?
  url            String?
  isFree         Boolean   @default(false)
  isAd           Boolean   @default(false)
  usage          String?   @db.Text
  howItHelps     String?   @db.Text
  launchDate     DateTime?
  sortOrder    Int       @default(0)
  isPublished  Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  categoryId   String
  category     TrendingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  industrySlug String?
  industry     Industry? @relation(fields: [industrySlug], references: [slug])

  @@index([categoryId])
  @@index([industrySlug])
  @@schema("content")
}

model Guide {
  id           String          @id @default(uuid())
  title        String
  description  String          @db.Text
  difficulty   DifficultyLevel @default(BEGINNER)
  timeRequired String
  toolsNeeded  String[]
  industrySlug String
  industry     Industry        @relation(fields: [industrySlug], references: [slug])
  whatYouLearn String          @db.Text
  steps        Json            @default("[]")
  sortOrder    Int             @default(0) @map("sort_order")
  isPublished  Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([industrySlug])
  @@schema("content")
}

model PromptTemplate {
  id           String   @id @default(uuid())
  title        String
  prompt       String   @db.Text
  useCase      String
  industrySlug String
  industry     Industry @relation(fields: [industrySlug], references: [slug])
  category     String
  sortOrder    Int      @default(0)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([industrySlug])
  @@schema("content")
}

model CareerPath {
  id              String   @id @default(uuid())
  industrySlug    String
  industry        Industry @relation(fields: [industrySlug], references: [slug])
  title           String
  description     String   @db.Text
  aiImpactSummary String   @db.Text
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  jobs CareerJob[]

  @@index([industrySlug])
  @@schema("content")
}

model CareerJob {
  id             String      @id @default(uuid())
  careerPathId   String
  careerPath     CareerPath  @relation(fields: [careerPathId], references: [id], onDelete: Cascade)
  title          String
  salaryRangeMin Int
  salaryRangeMax Int
  currency       String      @default("USD")
  demand         JobDemand   @default(GROWING)
  requiredDegree String
  requiredSkills String[]
  futureSkills   String[]
  howAiChanges   String      @db.Text
  timeline       JobTimeline @default(NOW)
  googleUrl      String?     @map("google_url")
  notebookLmUrl  String?     @map("notebook_lm_url")
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([careerPathId])
  @@schema("content")
}

model Skill {
  id            String          @id @default(uuid())
  name          String
  description   String          @db.Text
  industrySlug  String
  industry      Industry        @relation(fields: [industrySlug], references: [slug])
  level         DifficultyLevel @default(BEGINNER)
  whyItMatters  String          @db.Text
  learnUrl      String?
  notebookLmUrl String?         @map("notebook_lm_url")
  timeToLearn   String
  category      String
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([industrySlug])
  @@schema("content")
}

// ═══════════════════════════════════════════════════════════════════════
// NOTEBOOKS (AnythingLLM Integration)
// ═══════════════════════════════════════════════════════════════════════

enum NotebookCategory {
  MODELS
  AGENTS
  APPS
  CLASS

  @@schema("content")
}

enum SourceType {
  URL
  PDF
  TEXT
  VIDEO
  YOUTUBE

  @@schema("content")
}

model MasterNotebook {
  id               String           @id @default(uuid())
  industrySlug     String
  category         NotebookCategory
  title            String
  description      String?          @db.Text
  workspaceSlug    String?          @map("workspace_slug")
  workspaceCreated Boolean          @default(false) @map("workspace_created")
  gradeLevel       String?          @map("grade_level")
  difficultyLevel  String?          @map("difficulty_level")
  sourcesCount     Int              @default(0) @map("sources_count")
  published        Boolean          @default(false)
  createdBy        String           @map("created_by")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  industry     Industry              @relation(fields: [industrySlug], references: [slug])
  sources      NotebookSource[]
  accessLogs   NotebookAccessLog[]
  chatMessages NotebookChatMessage[]

  @@index([industrySlug])
  @@index([published])
  @@index([gradeLevel])
  @@map("master_notebooks")
  @@schema("content")
}

model NotebookSource {
  id         String         @id @default(uuid())
  notebookId String         @map("notebook_id")
  type       SourceType
  title      String
  url        String?
  filePath   String?        @map("file_path")
  metadata   Json?
  sortOrder  Int            @default(0) @map("sort_order")
  createdAt  DateTime       @default(now()) @map("created_at")

  notebook MasterNotebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@index([notebookId])
  @@map("notebook_sources")
  @@schema("content")
}

model NotebookAccessLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  notebookId String   @map("notebook_id")
  accessedAt DateTime @default(now()) @map("accessed_at")

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  notebook MasterNotebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@index([userId, notebookId])
  @@index([userId, accessedAt])
  @@map("notebook_access_logs")
  @@schema("user_activity")
}

model NotebookChatMessage {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  notebookId    String   @map("notebook_id")
  workspaceSlug String   @map("workspace_slug")
  message       String   @db.Text
  response      String   @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  notebook MasterNotebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@index([userId, notebookId])
  @@index([notebookId, createdAt])
  @@map("notebook_chat_messages")
  @@schema("user_activity")
}

// ═══════════════════════════════════════════════════════════════════════
// USER_NETWORK SCHEMA (Parent-Child & Teacher-Parent)
// ═══════════════════════════════════════════════════════════════════════

model ParentChildLink {
  parentId  String   @map("parent_id")
  childId   String   @map("child_id")
  createdAt DateTime @default(now()) @map("created_at")

  parent User @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  child  User @relation("ChildLinks", fields: [childId], references: [id], onDelete: Cascade)

  @@id([parentId, childId])
  @@map("parent_child_links")
  @@schema("user_network")
}

model TeacherNote {
  id        String   @id @default(uuid())
  teacherId String   @map("teacher_id")
  studentId String   @map("student_id")
  parentId  String?  @map("parent_id")
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  teacher User  @relation("TeacherNotes", fields: [teacherId], references: [id], onDelete: Cascade)
  student User  @relation("StudentNotes", fields: [studentId], references: [id], onDelete: Cascade)
  parent  User? @relation("ParentNotes", fields: [parentId], references: [id], onDelete: SetNull)

  @@index([teacherId])
  @@index([studentId])
  @@index([parentId])
  @@map("teacher_notes")
  @@schema("user_network")
}

// ═══════════════════════════════════════════════════════════════════════
// CLASS CHAT (Real-Time Student Messaging)
// ═══════════════════════════════════════════════════════════════════════

model ClassChat {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   String   @default("general")
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([channel, createdAt])
  @@index([userId])
  @@map("class_chats")
  @@schema("user_activity")
}

// ═══════════════════════════════════════════════════════════════════════
// ASK BUDDY (AI Chat Assistant)
// ═══════════════════════════════════════════════════════════════════════

enum BuddyMessageRole {
  USER
  ASSISTANT
  SYSTEM

  @@schema("user_activity")
}

model BuddyConversation {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String   @default("New Conversation")
  context   String?  @db.Text
  model     String   @default("placeholder")
  archived  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages BuddyMessage[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("buddy_conversations")
  @@schema("user_activity")
}

model BuddyMessage {
  id             String           @id @default(uuid())
  conversationId String           @map("conversation_id")
  role           BuddyMessageRole
  content        String           @db.Text
  metadata       Json             @default("{}")
  createdAt      DateTime         @default(now()) @map("created_at")

  conversation BuddyConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("buddy_messages")
  @@schema("user_activity")
}
